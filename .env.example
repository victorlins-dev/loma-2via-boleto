# === SGA / Hinova (read-only) — chave própria "jivo_bot" (reuso, decisão Victor 22/07) ===
# Server-only. NUNCA prefixar com NEXT_PUBLIC_. O valor real Victor seta na Vercel; Claude nunca vê.
SGA_HOST=https://api.hinova.com.br/api/sga/v2
SGA_USER=
SGA_PASSWORD=
SGA_TOKEN=

# === Bitrix (app local) ===
# 🔒 PIN DE PORTAL (OBRIGATÓRIO em prod): domínio do portal da Loma. TODA validação de sessão bate
# AQUI, nunca no domínio que o navegador manda. Sem isso o servidor recusa (fail-closed).
BITRIX_PORTAL_DOMAIN=lomacrm.bitrix24.com.br
# Defesa extra opcional: member_id do portal (vem na instalação). Se setado, exige que bata.
BITRIX_ALLOWED_MEMBER_ID=

# === Banco (Supabase / Postgres) — SEMPRE a string do POOLER (Transaction, porta 6543) ===
# Supabase → Project Settings → Database → Connection string → "Transaction pooler" (URI).
# Server-only. O app usa prepare:false (exigência do pooler transaction).
DATABASE_URL=

# ⚠️ ALLOW_DEV_NO_AUTH: SÓ desenvolvimento local. É ignorado quando NODE_ENV=production (blindado no
# código). NUNCA setar na Vercel.

# === App ===
BITRIX_FRAME_ANCESTORS=https://*.bitrix24.com.br https://*.bitrix24.com
SESSION_SECRET=
