  {
    "type": "post",
    "url": "mgf-lancamento/alterar",
    "title": "Alterar Lançamento",
    "name": "Alterar_lancamento",
    "description": "<p>Altera um lançamento no MGF</p>",
    "version": "2.0.0",
    "group": "MGF",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_lancamento",
            "description": "<p>Código do lançamento a ser alterado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_evento",
            "description": "<p>Código do evento vinculado ao lançamento. Caso seja enviado o código do associado ou veículo para alterar, este campo é obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_associado",
            "description": "<p>Código do associado vinculado ao lançamento. Caso seja enviado o código do associado ou veículo para alterar, este campo é obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo",
            "description": "<p>Código do associado vinculado ao lançamento. Caso seja enviado o código do associado ou veículo para alterar, este campo é obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_fornecedor",
            "description": "<p>Código da sub-operação do lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero_nota_fiscal",
            "description": "<p>Número da nota fiscal relacionada ao lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "controle_interno",
            "description": "<p>Altera o número de controle interno do lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "alterar_parcelas",
            "description": "<p>Array contendo os índices: <br> <code>parcela</code>(qual parcela do lançamento está se referindo)<br><code>codigo_situacao_parcela</code><br> <code>valor_parcela</code>(valor da parcela. Formato &quot;99,99&quot;. Opcional)<br> <code>valor_pagamento</code>(valor pago da parcela. Formato &quot;99,99&quot;. Opcional)<br> <code>data_vencimento</code>(data de vencimento da parcela. Formato &quot;dd/mm/yyyy&quot;. Opcional)<br><code>data_pagamento</code>(data de pagamento da parcela. Formato &quot;dd/mm/yyyy&quot;. Opcional)<br> <code>codigo_caixa_local</code> (Código do caixa local a ser alterado. Opcional) <br> <code>codigo_banco</code> (Código do banco a ser alterado. Opcional) <br> <code>juros</code>(opcional)<br><code>multa</code>(opcional)</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"codigo_lancamento\" : 999,\n    \"codigo_evento\" : 9,\n    \"codigo_associado\" : 99,\n    \"codigo_veiculo\" : 99,\n    \"codigo_fornecedor\" : 9,\n    \"numero_nota_fiscal\" : \"99999999999\",\n    \"controle_interno\" : \"999\",\n    \"alterar_parcelas\" :[\n        {\n            \"parcela\" : \"1\",\n            \"codigo_situacao_parcela\" : 9,\n            \"valor_parcela\" : \"999,99\",\n            \"data_vencimento\" : \"dd/mm/YYYY\",\n            \"data_pagamento\": \"dd/mm/YYYY\",\n            \"juros\" : \"999,99\",\n            \"multa\" : \"999,99\"\n        },\n        {\n            \"parcela\" : 2,\n            \"codigo_situacao_parcela\" : 9,\n            \"valor_parcela\" : \"999,99\",\n            \"data_vencimento\" : \"dd/mm/YYYY\",\n            \"data_pagamento\": \"dd/mm/YYYY\",\n            \"juros\" : \"99,99\",\n            \"multa\" : \"999,99\"\n        }\n    ]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 207 OK\n\n{\n    \"mensagem\": \"Alterado\",\n    \"codigo_lancamento\": \"999\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classMgf.php",
    "groupTitle": "MGF",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
  },
