  {
    "type": "post",
    "url": "listar/beneficiario",
    "title": "Listar",
    "name": "Listar_Benefici_rio",
    "description": "<p>Lista os beneficiários de acordo com a situação especificada</p>",
    "version": "2.0.0",
    "group": "Beneficiario",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "codigo_situacao",
            "description": "<p>Define qual a situação dos beneficiários a serem listados. O codigo_situacao é obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_voluntario",
            "description": "<p>Código do voluntário usado para consultar os beneficiários vinculados a esse voluntário em específico.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_associado",
            "description": "<p>Código do associado usado para consultar os beneficiários vinculados a esse associado em específico.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define que qual item a lista deve começar. Caso não seja enviado, a lista irá começar pelo primeiro item do retorno. <br> A paginação funciona como um OFFSET.<br>Se o parametro <code>quantidade_por_pagina</code> = 1000;<br>A página 1 se inicia em 0;<br>página 2 em 1000;<br>página 3 em 2000 e assim por diante.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n\t\"codigo_situacao\" : \"9\",\n\t\"inicio_paginacao\" : \"0\",\n\t\"quantidade_por_pagina\" : \"999\"\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"total_beneficiario\": \"37\",\n\t\"mostrando \": \"1\",\n\t\"numero_paginas\": 37,\n\t\"pagina_corrente\": 35,\n\t\"benficiarios\": [\n\t\t{\n\t\t\t\"codigo_beneficiario\": \"999\",\n\t\t\t\"codigo_associado\": \"99\",\n\t\t\t\"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n\t\t\t\"rg_beneficiario\": \"99999999\",\n\t\t\t\"data_expedicao_rg\": \"yyyy-mm-dd\",\n\t\t\t\"orgao_expedidor_rg\": \"MG\",\n\t\t\t\"cpf\": \"99999999\",\n\t\t\t\"cpf_associado\": \"9999999999\",\n\t\t\t\"data_nascimento\": \"yyyy-mm-ddT00:00:00-0300\",\n\t\t\t\"sexo\": \"M\",\n\t\t\t\"nome_mae\": \"PAI\",\n\t\t\t\"nome_mae\": \"MÃE\",\n\t\t\t\"cnh\": \"99999999\",\n\t\t\t\"categoria_cnh\": \"A\",\n\t\t\t\"logradouro\": \"RUA MANOEL ELIAS DE AGUIAR\",\n\t\t\t\"numero\": \"9\",\n\t\t\t\"complemento\": \"99\",\n\t\t\t\"bairro\": \"OURO PRETO\",\n\t\t\t\"cidade\": \"BELO HORIZONTE\",\n\t\t\t\"estado\": \"SC\",\n\t\t\t\"cep\": \"99999-999\",\n\t\t\t\"telefone\": \"999999999\",\n\t\t\t\"ddd\": 99,\n\t\t\t\"telefone_celular\": \"99\",\n\t\t\t\"ddd_celular\": 99999999,\n\t\t\t\"telefone_celular_aux\": \"99999999\",\n\t\t\t\"ddd_celular_aux\": 99,\n\t\t\t\"telefone_comercial\": \"999999999\",\n\t\t\t\"ddd_comercial\": 99,\n\t\t\t\"email\": \"Hinova@hinova.com.br\",\n\t\t\t\"email_auxiliar\": \"hinova@aux.com.br\",\n\t\t\t\"data_cadastro_beneficiario\": \"yyyy-mm-dd\",\n\t\t\t\"data_contrato_beneficiario\": \"yyyy-mm-dd\",\n\t\t\t\"hora_contrato_beneficiario\": \"99:99:99\",\n\t\t\t\"codigo_situacao\": \"9\",\n\t\t\t\"descricao_situacao\": \"ATIVO\",\n\t\t\t\"radio\": \"999\",\n\t\t\t\"radio2\": \"999\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classBeneficiario.php",
    "groupTitle": "Beneficiario",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
