  {
    "type": "post",
    "url": "listar/alteracao-associados/",
    "title": "Listar Alterações de Associados",
    "name": "Listar_Altera__es_Associados",
    "description": "<p>Lista as alterações de associados em um intervalo de até 7 dias</p>",
    "version": "2.0.0",
    "group": "Associado",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_inicial",
            "description": "<p>Data inicial da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_final",
            "description": "<p>Data final da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "ultima_alteracao",
            "description": "<p>Define se será exibida apenas a última alteração de cada associado . Formato &quot;Y&quot; ou &quot;N&quot;. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "allowedValues": [
              "\"conta_debito\"",
              "\"conta_debito_dv\"",
              "\"contato\"",
              "\"cpf\"",
              "\"data_contrato\"",
              "\"data_contrato_final\"",
              "\"data_nascimento\"",
              "\"ddd\"",
              "\"ddd_celular\"",
              "\"ddd_celular_aux\"",
              "\"ddd_comercial\"",
              "\"ddd_radio\"",
              "\"ddd_radio_aux\"",
              "\"email\"",
              "\"email_auxiliar\"",
              "\"estado\"",
              "\"formato_geracao_boleto\"",
              "\"gerar_cobranca\"",
              "\"codigo_banco\"",
              "\"codigo_operadora\"",
              "\"codigo_profissao\"",
              "\"codigo_regional\"",
              "\"codigo_situacao\"",
              "\"codigo_vencimento\"",
              "\"logradouro\"",
              "\"naturalidade\"",
              "\"nome\"",
              "\"numero\"",
              "\"qtde_parcela\"",
              "\"radio\"",
              "\"radio2\"",
              "\"receber_email\"",
              "\"receber_sms\"",
              "\"receber_whatsapp\"",
              "\"rg\"",
              "\"telefone\"",
              "\"telefone_celular\"",
              "\"telefone_celular_aux\"",
              "\"telefone_comercial\"",
              "\"telefone_fax\"",
              "\"telefone_radio\"",
              "\"telefone_radio_aux\"",
              "\"tipo_boleto_associado\"",
              "\"tipo_boleto_beneficiario\"",
              "\"tipo_boleto_veiculo\"",
              "\"valor_fixo\""
            ],
            "optional": false,
            "field": "campos",
            "description": "<p>Array contendo o nome dos campos do associado que devem ser retornados</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "valor_posterior",
            "description": "<p>Array contendo o VALOR dos campos do associado que devem ser retornados. O endpoint ira buscar as alterações de associado que foram alterados para o valor informado neste campo.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n\t\"data_inicial\" : \"dd/mm/yyyy\",\n\t\"data_final\" : \"dd/mm/yyyy\",\n\t\"campos\" : [\n\t\t\"codigo_situacao\", \n\t\t\"nome\", \n\t\t\"cpf\"\n\t],\n\t\"valor_posterior\" : [\n\t\t\"11111\", \n\t\t\"XXXXXXXX\", \n\t\t\"111111\"\n\t],\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
