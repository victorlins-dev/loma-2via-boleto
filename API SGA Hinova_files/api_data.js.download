  {
    "type": "get",
    "url": "listar/voluntario/:situacao/:pagina",
    "title": "Listar",
    "description": "<p>Lista os voluntários que estão vinculados a cooperativas nas quais o usuário tem permissão.<br>No array &quot;cooperativas&quot;, cada índice dele representa o código da cooperativa, e o valor representa o nome da cooperativa</p>",
    "name": "Listar_Voluntario",
    "version": "2.0.0",
    "group": "Voluntario",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "pagina",
            "description": "<p>Número da página que se deseja retornar. Por padrão, o valor é 0. Serão listados sempre 5000 registros por página, e a página sempre inicia em 0.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "ativo",
              "inativo",
              "todos"
            ],
            "optional": false,
            "field": "situacao",
            "description": "<p>Define qual a situação dos objetos a serem retornados.</br><code>todos</code>: retorna ativos e inativos.</br><code>ativo</code>: retorna apenas ativos.</br><code>inativo</code>: retorna apenas inativos.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "listar/voluntario/ativo",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição:",
        "content": "listar/voluntario/ativo/1",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_voluntario\": \"9\",\n\t\"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n\t\"cpf\": \"999999999999\",\n\t\"cep\": \"99999999\",\n\t\"codigo_classificacao\": \"9\",\n\t\"telefone\": \"(99)9999-9999\",\n\t\"celular\": \"(99)99999-9999\",\n\t\"telefone_comercial\": \"(99)9999-9999\",\n\t\"email\": \"hinova@hinova.com.br\",\n\t\"logradouro\": \"MANOEL ELIAS AGUIAR\",\n\t\"numero\": \"245\",\n\t\"complemento\": \"\",\n\t\"bairro\": \"OURO PRETO\",\n\t\"cidade\": \"BELO HORIZONTE\",\n\t\"estado\": \"MG\",\n\t\"cep\": \"99999999\",\n\t\"situacao\": \"ATIVO\",\n\t\"formato_pagamento\": \"R$\",\n\t\"valor_pagamento\": \"999.99\",\n\t\"formato_pagamento_residual\": \"%\",\n\t\"valor_pagamento_residual\": \"99.99\",\n\t\"codigo_classificacao\": \"9\",\n\t\"obs\": \"observação\",\n\t\"cooperativas\": [\n\t\t{\n\t\t\t\"codigo_cooperativa\": \"9\",\n\t\t\t\"nome_cooperativa\": \"HINOVA SOLUÇÕES DIGITAIS\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classVoluntario.php",
    "groupTitle": "Voluntario",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
