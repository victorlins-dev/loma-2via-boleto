  {
    "type": "post",
    "url": "listar/alteracao-historico-atendimento/",
    "title": "Listar Alterações de Histórico Atendimento",
    "name": "Listar_Altera__es_Hist_rico_Atendimento",
    "description": "<p>Lista as alterações de Histórico Atendimento em um intervalo de até 7 dias</p>",
    "version": "2.0.0",
    "group": "Atendimento",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_inicial",
            "description": "<p>Data inicial da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_final",
            "description": "<p>Data final da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ultima_alteracao",
            "description": "<p>Define se será exibida apenas a última alteração de cada histórico atendimento . Formato &quot;Y&quot; ou &quot;N&quot;. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint de 5000</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define se será exibida apenas a última alteração de cada histórico atendimento . Formato &quot;Y&quot; ou &quot;N&quot;. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "campos",
            "description": "<p>Array contendo o nome dos campos do histórico atendimento que devem ser retornados</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n\t\"data_inicial\": \"dd/mm/yyyy\",\n\t\"data_final\": \"dd/mm/yyyy\",\n\t\"ultima_alteracao\": \"Y\",\n\t\"campos\": [\n\t\t\"codigo_status_atendimento\", \n\t\t\"codigo_veiculo\",\n\t\t\"valor_atendimento\"\n\t]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
