  {
    "type": "post",
    "url": "/boleto/cadastrar",
    "title": "Cadastrar",
    "name": "Cadastrar",
    "version": "2.0.0",
    "group": "Boleto",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado ao qual o boleto pertence</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_regional",
            "description": "<p>Código da regional a qual o associado pertence</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_conta",
            "description": "<p>Código do banco. Obrigatório caso tenha mais de uma conta bancária cadastrada para a regional</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_situacao",
            "description": "<p>Código da situação do boleto</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "mes_referente",
            "description": "<p>Mês referente do boleto</p>"
          },
          {
            "group": "Parameter",
            "type": "Bool",
            "optional": false,
            "field": "link_boleto",
            "description": "<p>Retorna o link do boleto</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "array_parcela",
            "description": "<p>Array contendo os índices: <code>valor</code> (valor da parcela)<code>vencimento</code>(data de vencimento do boleto). Para gerar carnê, adicione uma nova posição <code>valor</code> e <code>vencimento</code> conforme Exemplo Requisição</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "array_parcela.valor",
            "description": "<p>Valor que será cobrado no boleto</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "array_parcela.vencimento",
            "description": "<p>Dia do vencimento do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "referencia",
            "description": "<p>Array contendo os índices: <code>modulo</code>, <code>codigo_modulo</code>, <code>descricao</code>(descrição do boleto), <code>codigo_produto</code>, <code>valor</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "referencia.modulo",
            "description": "<p>módulo referente do boleto, ele pode ser: beneficiário, veiculo ou cliente</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "referencia.codigo_modulo",
            "description": "<p>código do módulo, se o módulo for &quot;beneficiário&quot;, o código_modulo será o código do beneficiário, se for &quot;veiculo&quot; será o código do veículo e se for &quot;cliente&quot; será o código do cliente</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "referencia.descricao",
            "description": "<p>descrição do boleto</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "referencia.codigo_produto",
            "description": "<p>código do produto incluso no boleto, caso não tenham produtos não é preciso incluir este índice</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "referencia.valor",
            "description": "<p>valor da referência</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>e-Mail do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero_banco",
            "description": "<p>Número do banco do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao",
            "description": "<p>Data de emissão do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "dados_baixa",
            "description": "<p>Array contendo os índices: <code>data_pagamento</code>, <code>data_credito_banco</code>, <code>valor_pagamento</code>, <code>codigo_forma_pagamento</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "dados_baixa.data_pagamento",
            "description": "<p>Data do Pagamento. Obrigatório caso seja enviado o parâmetro <code>dados_baixa</code>.<br>Mascara: <code>&quot;dd/mm/yyyy&quot;</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "dados_baixa.data_credito_banco",
            "description": "<p>Data de crédito no banco.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "dados_baixa.valor_pagamento",
            "description": "<p>Valor de pagamento do boleto, caso seja omitido o valor será o total do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "dados_baixa.codigo_forma_pagamento",
            "description": "<p>Código da forma de pagamento do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_boleto",
            "description": "<p>Código do tipo de boleto. <br>Lista de tipo de boleto {<a href=\"#api-Boleto-Listar_Tipo_Boleto\">aqui</a>}.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_cobranca_recorrente",
            "description": "<p>Código do tipo de cobrança recorrente. <br>Lista de tipo cobranca recorrente {<a href=\"#api-Boleto-Listar_tipo_cobran_a_recorrente\">aqui</a>}.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
