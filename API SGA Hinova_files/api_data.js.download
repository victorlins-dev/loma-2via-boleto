  {
    "type": "post",
    "url": "/associado/cadastrar",
    "title": "Cadastrar",
    "name": "Cadastrar",
    "version": "2.0.0",
    "group": "Associado",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "nome",
            "description": "<p>Nome do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpf",
            "description": "<p>CPF ou CNPJ válido do associado. Marcara: 999.999.999-99, 99.999.999/9999-99 ou somente números</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "rg",
            "description": "<p>Registro geral do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_nascimento",
            "description": "<p>Data de nascimento do associado. Mascara: dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "logradouro",
            "description": "<p>Logradouro residêncial do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "numero",
            "description": "<p>Número residêncial do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "bairro",
            "description": "<p>Bairro residêncial do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cidade",
            "description": "<p>Cidade residêncial do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "estado",
            "description": "<p>Estado residêncial do associado. Informar DESCRIÇÃO ou SIGLA</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cep",
            "description": "<p>Cep residêncial do associado. Mascara: 99999-999 ou 99.999-999 ou somente números</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_conta",
            "description": "<p>Código do banco. Obrigatório caso tenha mais de uma conta bancária cadastrada para a regional</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "sexo",
            "description": "<p>Sexo do associado. Valores aceitos M ou F.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone",
            "description": "<p>Número de telefone do associado. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "mes_referente",
            "description": "<p>Mês referente</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento residêncial do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "orgao_expedidor_rg",
            "description": "<p>Órgão expedidor do RG.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_expedicao_rg",
            "description": "<p>Data da expedição do RG. . Mascara: dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_comercial",
            "description": "<p>Telefone comercial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "celular",
            "description": "<p>Número de celular do associado. . Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_celular_aux",
            "description": "<p>Número de celular auxiliar do associado. . Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>e-Mail do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email_auxiliar",
            "description": "<p>e-mail auxiliar do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_profissao",
            "description": "<p>Código profissão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_regional",
            "description": "<p>Código regional.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "dia_vencimento",
            "description": "<p>Dia do mês no qual o boleto irá vencer.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_externo",
            "description": "<p>Código externo do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_habilitacao",
            "description": "<p>Data de Vencimento da habilitação do associado. Mascara: dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_primeira_habilitacao",
            "description": "<p>Data de emissão da primeira habilitação do associado. Mascara: dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "categoria_cnh",
            "description": "<p>Categoria da CNH do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero_cnh",
            "description": "<p>Número da CNH do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato",
            "description": "<p>Data do contrato do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fixo",
            "description": "<p>Valor fixo mensal</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "receber_whatsapp",
            "description": "<p>Receber whatsapp. Mascara: Y ou N</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_voluntario",
            "description": "<p>Código do voluntário responsável pela adesão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "qtde_parcela_carne",
            "description": "<p>Quantidade de parcelas do carnê.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_como_conheceu",
            "description": "<p>Código da mídia pela qual o associado conheceu a associação.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "observacao",
            "description": "<p>Observação do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "beneficios",
            "description": "<p>Array contendo os códigos dos benefícios a serem vinculados ao associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "cartao",
            "description": "<p>Array contendo os dados do cartão de crédito do associado.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado inserido na base de dados</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"nome\" : \"Hinova Soluções Digitais\",\n\t\"cpf\" :\t\"99.999.999/9999-99 ou 999.999.999-99\",\n\t\"rg\" : \"999999\",\n\t\"data_nascimento\" :\t\"dd/mm/yyyy\",\n\t\"telefone\" : \"(99) 99999-9999\",\n\t\"celular\" :\t\"(99) 99999-9999\",\n\t\"email\" : \"teste@hinova.com.br\",\n\t\"logradouro\" : \"Rua Manoel Elias de Aguiar\",\n\t\"numero\" : \"245\",\n\t\"complemento\" :\t\"Comercial\",\n\t\"bairro\" : \"Ouro Preto\",\n\t\"cidade\" : \"Belo Horizonte\",\n\t\"estado\" : \"Minas Gerais\",\n\t\"cep\" :\t\"31.330-520\",\n\t\"codigo_profissao\" : 9,\n\t\"codigo_regional\" :\t9,\n\t\"codigo_cooperativa\": 9,\n\t\"codigo_conta\" : 99,\n\t\"dia_vencimento\" : 99,\n\t\"codigo_externo\" : 9,\n\t\"sexo\" : \"M\",\n\t\"data_vencimento_habilitacao\" : \"dd/mm/yyyy\",\n\t\"data_primeira_habilitacao\" : \"dd/mm/yyyy\",\n\t\"categoria_cnh\" : \"A\",\n\t\"numero_cnh\" : \"999999999\",\n\t\"data_contrato\" : \"dd/mm/yyyy\",\n\t\"valor_fixo\" : \"99,99\",\n\t\"mes_referente\" : \"mm/yyyy\",\n\t\"qtde_parcela_carne\" : 9,\n\t\"codigo_como_conheceu\" : 9,\n\t\"beneficios\" : [\n\t\t{\n\t\t\t\"codigo_beneficio\" : 9\n\t\t},\n\t\t{\n\t\t\t\"codigo_beneficio\" : 99\t\n\t\t}\n\t]\n\t\"cartao\" : {\n\t\t\"numero_final_cartao\" : \"999\",\n\t\t\"codigo_bandeira_cartao\" : 999\n\t\t\"hash\" : \"9999999999\",\n\t\t\"validade\" : \"mm/yyyy\"\n\t}\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\"\t\t\t: \t\"OK\",\n\t\"codigo_associado\"\t:\t999999,\n\t\"beneficios\": [\n\t\t{\n\t\t\t\"codigo_beneficio\": \"9\",\n\t\t\t\"situacao\": \"Benefício adicionado ao associado\"\n\t\t},\n\t\t{\n\t\t\t\"codigo_beneficio\": \"99\",\n\t\t\t\"situacao\": \"Benefício adicionado ao associado\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classAssociado.php",
    "groupTitle": "Associado",
    "header": {
