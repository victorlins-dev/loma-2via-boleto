  {
    "type": "post",
    "url": "listar/alteracao-eventos",
    "title": "Listar Histórico Alteração",
    "description": "<p>Listar o histórico de alteração do evento</p>",
    "name": "Listar_Evento_Historico",
    "version": "2.0.0",
    "group": "Evento",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_inicial",
            "description": "<p>Data inicial da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "data_final",
            "description": "<p>Data final da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Se não for enviado, o início da paginação será 0 e deve ser incrementado de 1 em 1.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Define a quantidade de registros exibidos por página. Se não for enviado, a quantidade de registros por página será de 100.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "allowedValues": [
              "\"codigo_vistoriador\"",
              "\"codigo_eventocondutor\"",
              "\"codigo_eventomotivo\"",
              "\"logradouro\"",
              "\"numero\"",
              "\"complemento\"",
              "\"bairro\"",
              "\"cidade\"",
              "\"estado\"",
              "\"cep\"",
              "\"descricao_evento\"",
              "\"descricao_evento_area\"",
              "\"responsavel_bo\"",
              "\"descricao_bo\"",
              "\"numero_bo\"",
              "\"data_bo\"",
              "\"data_comunicado_evento\"",
              "\"hora_comunicado_evento\"",
              "\"data_evento\"",
              "\"hora_evento\"",
              "\"participacao\"",
              "\"tipo_participacao\"",
              "\"origem_abertura\"",
              "\"local_sinalizado\"",
              "\"sinalizacao_local\"",
              "\"valor_reparo\""
            ],
            "optional": false,
            "field": "campos",
            "description": "<p>Array contendo o nome dos campos do evento que devem ser retornados</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"data_inicial\": \"dd/mm/yyyy\",\n    \"data_final\": \"dd/mm/yyyy\",\n    \"campos\": [\n        \"codigo_evento_situacao\"\n    ]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "{\n    \"paginacao\": {\n        \"total\": 999,\n        \"numero_paginas\": 9,\n        \"mostrando\": 9,\n        \"pagina_corrente\": 1\n    },\n    \"resultado\": [\n        {\n            \"protocolo_evento\": \"00000000\",\n            \"codigo\": \"99999\",\n            \"codigo_evento\": \"999\",\n            \"nome_campo_tabela\": \"hora_comunicado_evento\",\n            \"valor_anterior\": \"\",\n            \"valor_posterior\": \"12:59:54\",\n            \"codigo_usuario_alteracao\": \"9\",\n            \"nome_usuario_alteracao\": \"HINOVA SOLUÇÕES DIGITAIS\",\n            \"data_alteracao\": \"DATA HORA\",\n        }\n    ]\n}",
          "type": "json"
        }
      ]
    },
