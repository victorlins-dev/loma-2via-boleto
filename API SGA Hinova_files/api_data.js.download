    "url": "associado/buscar-por-permissao/:cpfOuCodigo/:buscar_por",
    "title": "Buscar por permissao",
    "name": "Buscar_por_permissao_por_CPF_ou_codigo",
    "description": "<p>Busca associado pelo CPF ou pelo código validando as permissões em regional e cooperativa do usuário</p>",
    "version": "2.0.0",
    "group": "Associado",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpfOuCodigo",
            "description": "<p>CPF ou código do associado a ser pesquisado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "codigo",
              "cpf"
            ],
            "optional": false,
            "field": "buscar_por",
            "description": "<p>Define se o parâmetro cpfOuCodigo é o CPF ou o código do associado</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "/associado/buscar-por-permissao/buscar/999.999.999-99",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\t\n\t\"codigo_associado\": \"99\",\n\t\"codigo_associado_beneficiario\": \"999\",\n\t\"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n\t\"sexo\": \"M\",\n\t\"data_nascimento\": \"yyyy-mm-dd\",\n\t\"nome_mae\": \"MAE\",\n\t\"nome_pai\": \"PAI\",\n\t\"rg\": \"MG 99999999\",\n\t\"orgao_expedidor_rg\": \"SSPMG\",\n\t\"data_expedicao_rg\": \"yyy-mm-dd\",\n\t\"cnh\": \"999999999999\",\n\t\"categoria_cnh\": \"A\",\n\t\"data_vencimento_habilitacao\": \"yyyy-mm-dd\",\n\t\"cpf\": \"999.999.999-99\",\n\t\"telefone_fixo\": \"(99)9999-9999\",\n\t\"telefone_celular\": \"(99)99999-9999\",\n\t\"telefone_celular_aux\": \"(99)99999-9999\",\n\t\"telefone_comercial\": \"(99)9999-9999\",\n\t\"email\": \"hinova@hinova.com.br\",\n\t\"email_auxiliar\": \"hinova.aux@hinova.com\",\n\t\"cep\": \"99999-99\",\n\t\"logradouro\": \"RUA MANOEL ELIAS DE AGUIAR\",\n\t\"numero\": \"245\",\n\t\"complemento\": \"COMERCIAL\",\n\t\"bairro\": \"OURO PRETO\",\n\t\"cidade\": \"BELO HORIZONTE\",\n\t\"estado\": \"MG\",\n\t\"codigo_regional\": \"9\",\n\t\"codigo_cooperativa\": \"9\",\n\t\"codigo_externo\": \"AAA999\",\n\t\"codigo_situacao\": \"9\",\n\t\"codigo_voluntario\": \"9\",\n\t\"codigo_estado_civil\": \"9\",\n\t\"descricao_situacao\": \"ATIVO\",\n\t\"veiculos\": [\n\t\t{\n\t\t\t\"codigo_veiculo\": \"999\",\n\t\t\t\"placa\": \"AAA-111\",\n\t\t\t\"chassi\": \"999999999999\",\n\t\t\t\"valor_fixo\" : 99.99\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classAssociado.php",
    "groupTitle": "Associado",
