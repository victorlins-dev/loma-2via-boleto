            "field": "codigo_tipo_adesao",
            "description": "<p>Código do tipo de adesão do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_carroceria",
            "description": "<p>Código do tipo de carroceria do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_grupo_produto",
            "description": "<p>Código do grupo de produto do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_cobranca_recorrente",
