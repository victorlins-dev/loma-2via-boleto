            "field": "codigo_alienacao",
            "description": "<p>Código da alienação fiduciária.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_combustivel",
            "description": "<p>Código do combustível do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cor",
            "description": "<p>Código da cor do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_categoria_veiculo",
            "description": "<p>Código da categoria veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento correspondência</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
