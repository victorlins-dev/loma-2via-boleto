  {
    "type": "post",
    "url": "/modelo/listar",
    "title": "Listar Modelos",
    "description": "<p>Lista Veículos Cadastrados no SGA. Limite 200 modelos no retorno por requisição.</p>",
    "name": "listar_modelos",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "situacao",
            "description": "<p>Situação dos modelos a serem retornados. Este parâmetro pode ser &quot;ativo&quot;, &quot;inativo&quot; ou &quot;todos&quot;. Obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define que qual item a lista deve começar. Caso não seja enviado, a lista irá começar pelo primeiro item do retorno. <br> A paginação funciona como um OFFSET.<br>Se o parametro <code>quantidade_por_pagina</code> = 1000;<br>A página 1 se inicia em 0;<br>página 2 em 1000;<br>página 3 em 2000 e assim por diante.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"situacao\": \"ativo\",\n\t\"inicio_paginacao\" : 0 ,\n\t\"quantidade_por_pagina\" : 50\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_modelo\": \"9999\",\n\t\"descricao_modelo\": \"MODELO\",\n\t\"codigo_marca\": \"99\",\n\t\"descricao_marca\": \"MARCA\",\n\t\"codigo_tipo_veiculo\": \"9\",\n\t\"descricao_tipo_veiculo\": \"AUTOMÓVEL\",\n\t\"situacao\": \"ATIVO\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classVeiculo.php",
    "groupTitle": "Veiculo",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
  },
  {
    "type": "post",
    "url": "/cadastrar/vistoria",
    "title": "Cadastrar vistoria",
    "description": "<p>Cadastra uma vistoria vinculada a um associado</p>",
    "name": "Cadastrar_vistoria",
    "version": "2.0.0",
    "group": "Vistoria",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado para quem a vistoria foi feita</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_tipo_vistoria",
            "description": "<p>Código do tipo da vistoria.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_vistoria",
            "description": "<p>Data em que foi realizada a vistoria</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_vistoriador",
            "description": "<p>Código do vistoriador que realizou a vistoria</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo vistoriado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_estado_pneu",
            "description": "<p>Código do estado do pneu.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_vistoria",
            "description": "<p>Valor da vistoria.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "observacao",
            "description": "<p>Obervação da vistoria.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "longitude",
            "description": "<p>Longitude da localização da vistoria.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "latitude",
            "description": "<p>Latitude do local da vistoria.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_recebimento_vistoria",
            "description": "<p>Data do recebimento da vistoria.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n    \"codigo_associado\" : 999,\n    \"codigo_vistoriador\" : 9,\n    \"codigo_veiculo\" : 99,\n    \"codigo_tipo_vistoria\" : 9,\n    \"codigo_estado_pneu\" : 9,\n    \"data_vistoria\" : \"dd/mm/yyyy\",\n    \"observacao\" : \"feito pela api v2\",\n    \"latitude\" : \"-99.9999\",\n    \"longitude\" : \"-99.9999\",\n    \"valor_vistoria\" : \"99,99\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n    \"mensagem\": \"OK\",\n    \"codigo_vistoria\": \"999\"\n}",
          "type": "json"
        }
      ]
    },
