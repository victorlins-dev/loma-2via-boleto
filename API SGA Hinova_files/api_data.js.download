  {
    "type": "get",
    "url": "mgf-descricao/listar/:situacao",
    "title": "Listar Descrição",
    "description": "<p>Lista as descrições disponíveis de acordo com a situação desejada, esta situação pode ser: Ativo, Inativo ou Todos. Obs: A situação é obrigatória</p>",
    "name": "Listar_Descricao",
    "version": "2.0.0",
    "group": "MGF",
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "/mgf-descricao/listar/ativo",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"codigo_descricao\": \"9\",\n\t\t\"codigo_suboperacao\": \"9\",\n\t\t\"descricao\": \"DESCRIÇÃO\",\n\t\t\"situacao\": \"ATIVO\"\n\t}\n]",
          "type": "json"
        }
      ]
    },
    "filename": "class/classMgf.php",
    "groupTitle": "MGF",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    },
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "ativo",
              "inativo",
              "todos"
            ],
            "optional": false,
            "field": "situacao",
            "description": "<p>Define qual a situação dos objetos a serem retornados.</br><code>todos</code>: retorna ativos e inativos.</br><code>ativo</code>: retorna apenas ativos.</br><code>inativo</code>: retorna apenas inativos.</p>"
          }
        ]
      }
