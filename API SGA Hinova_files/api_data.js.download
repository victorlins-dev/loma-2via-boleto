  {
    "type": "get",
    "url": "listar/vencimento/:situacao",
    "title": "Listar vencimento",
    "description": "<p>Lista os vencimentos disponíveis de acordo com a situação desejada, esta situação pode ser: Ativo, Inativo ou Todos. Obs: A situação é obrigatória</p>",
    "name": "Lista_Vencimento",
    "version": "2.0.0",
    "group": "Beneficiario",
    "examples": [
      {
