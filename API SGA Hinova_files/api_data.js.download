  {
    "type": "post",
    "url": "/buscar/rateio-medio",
    "title": "Buscar rateio",
    "description": "<p>Calcula o rateio médio para veículos de uma determinada cota, baseando-se no valor fipe, tipo veículo e regional.</p>",
    "name": "Buscar_rateio_m_dio",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "valor_fipe",
            "description": "<p>Valor fipe do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_regional",
            "description": "<p>Código da regional do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_tipo_veiculo",
            "description": "<p>Código do tipo do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_meses_media",
            "description": "<p>Quantidade de meses que serão usados para calcular a média do rateio. Caso não seja enviado a média será calculada baseada nos últimos 3 meses</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "valor_rateio_medio",
            "description": "<p>Valor do rateio médio para o veículo</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"valor_fipe\" : \"99999,99\",\n\t\"codigo_regional\" : 9,\n\t\"codigo_tipo_veiculo\" : \"9\",\n\t\"quantidade_meses_media\" : \"9\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"valor_rateio_medio\": \"R$ 99,99\"\n}",
          "type": "json"
        }
      ]
    },
