  {
    "type": "post",
    "url": "/listar/alteracao-veiculos",
    "title": "Listar Alterações de Veículos",
    "description": "<p>Lista as alterações de veículos em um intervalo de até 7 dias</p>",
    "name": "Listar_Altera__o_Ve_culo",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_inicial",
            "description": "<p>Data inicial da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_final",
            "description": "<p>Data final da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "valor_anterior",
            "description": "<p>Array contendo os valores anteriores</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "valor_posterior",
            "description": "<p>Array contendo os valores posteriores</p>"
          },
          {
            "group": "Parameter",
            "type": "int",
            "optional": true,
            "field": "codigo_objeto",
            "description": "<p>Inteiro contendo o codigo do objeto</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ultima_alteracao",
            "description": "<p>Define se será exibida apenas a última alteração de cada veículo. Formato &quot;Y&quot; ou &quot;N&quot;. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "allowedValues": [
