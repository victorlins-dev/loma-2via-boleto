  {
    "type": "post",
    "url": "fornecedor/cadastrar",
    "title": "Cadastrar",
    "description": "<p>Cadastra um fornecedor na base de dados.</p>",
    "name": "Cadastrar",
    "version": "2.0.0",
    "group": "Fornecedor",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpf",
            "description": "<p>CPF ou CNPJ válido do fornecedor. Mascara: 999.999.999-99, 99.999.999/9999-99 ou somente números</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "nome",
            "description": "<p>Nome do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "telefone",
            "description": "<p>Número de telefone da cooperativa. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "nome_fantasia",
            "description": "<p>Nome fantasia do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro do  fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade do fornecedor</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado do fornecedor. Informar DESCRIÇÃO ou SIGLA</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep do fornecedor. Mascara: 99999-999 ou 99.999-999 ou somente números</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>e-Mail do fornecedor.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigo_fornecedor",
            "description": "<p>Código do fornecedor inserido na base de dados</p>"
          }
        ]
      },
