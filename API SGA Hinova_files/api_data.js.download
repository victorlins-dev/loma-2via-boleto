          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "beneficios",
            "description": "<p>Array contendo os códigos do(s) benefício(s)</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigobeneficiario",
            "description": "<p>Código do beneficiário que recebeu o vínculo dos benefícios</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "beneficios_vinculados",
            "description": "<p>Array contendo informações dos benefícios vinculados ao beneficiário</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "beneficios_nao_vinculados",
            "description": "<p>Array contendo os benefícios que não foi possível vincular ao beneficiário. Obs: Esta posição só irá aparecer caso algum dos benefícios enviados não possa ser vinculado ao beneficiário</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_beneficiario\" :\t\"9\",\n\t\"beneficios\": [\n\t\t\"9\",\n\t\t\"99\",\n\t\t\"999\"\t\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_beneficiario\": \"9\",\n\t\"beneficios_vinculados\": [\n\t\t{\n\t\t\t\"codigo_beneficio\": \"99\",\n\t\t\t\"descricao_beneficio\": \"ASSISTÊNCIA\",\n\t\t\t\"codigo_fornecedor\": \"999\"\n\t\t}\n\t],\n\t\"beneficios_nao_vinculados\": [\n\t\t{\n\t\t\t\"codigo_beneficio\": \"99\",\n\t\t\t\"alerta\": \"Benefício não disponível para este perfil de beneficiário\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classBeneficio.php",
    "groupTitle": "Beneficio"
  },
