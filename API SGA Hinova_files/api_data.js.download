  {
    "type": "post",
    "url": "boleto/listar-alteracao",
    "title": "Listar Alterações de Boleto",
    "description": "<p>Lista o histórico de alteração dos boletos.</p>",
    "name": "Listar_Altera__o_Ve_culo",
    "version": "2.0.0",
    "group": "Boleto",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_inicial",
            "description": "<p>Data inicial da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_final",
            "description": "<p>Data final da pesquisa. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "allowedValues": [
              "\"codigo_barras\"",
              "\"data_credito_banco\"",
              "\"data_pagamento\"",
              "\"data_vencimento\"",
              "\"demonstrativo\"",
              "\"exibicao_extrato_rateio\"",
              "\"formato_geracao_boleto\"",
              "\"codigo_associado\"",
              "\"codigo_banco\"",
              "\"codigo_cliente\"",
              "\"codigo_forma_pagamento\"",
              "\"codigo_lote\"",
              "\"codigo_parcelamento_mgf\"",
              "\"codigo_parcelamento_mgf_tarifa_banco\"",
              "\"codigo_regional\"",
              "\"codigo_situacao\"",
              "\"codigo_tipo_boleto\"",
              "\"codigo_tipo_cobranca_recorrente\"",
              "\"codigo_usuario_cobranca\"",
              "\"instrucao\"",
              "\"instrucao_desconto\"",
              "\"linha_digitavel\"",
              "\"lote_distribuicao_cobranca\"",
              "\"mes_referente\"",
              "\"nao_receber_pagamento_apos\"",
              "\"parcela_paga\"",
              "\"parcelado\"",
              "\"qtde_parcela\"",
              "\"referente\"",
              "\"referente_sinistro\"",
              "\"tarifa_cobranca_banco\"",
              "\"valor\"",
              "\"valor_boleto_instrucao_desconto\"",
              "\"valor_original\"",
              "\"valor_pagamento\""
            ],
            "optional": false,
            "field": "campos",
            "description": "<p>Array contendo o nome dos campos do boleto que deseja ver se foram alterados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ultima_alteracao",
            "description": "<p>Define se será exibida apenas a última alteração de cada boleto. Formato &quot;Y&quot; ou &quot;N&quot;. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Inicia apartir de 0 e deve ser acrescentado de 1 em 1 para navegar através das proximas páginas. Opcional</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          }
        ]
      }
    },
    "success": {
