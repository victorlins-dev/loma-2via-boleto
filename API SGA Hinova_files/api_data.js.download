define({ "api": [
  {
    "type": "post",
    "url": "/alterar/associado",
    "title": "Alterar",
    "name": "Alterar",
    "version": "2.0.0",
    "group": "Associado",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado a ser alterado. Opcional caso esteja enviando o CPF do associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "nome",
            "description": "<p>Nome do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cpf",
            "description": "<p>CPF ou CNPJ válido do associado. Marcara: 999.999.999-99, 99.999.999/9999-99 ou somente números. Opcional caso esteja enviando o codigo_associado. Para alterar o CPF do associado é preciso enviar o código do associado também.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "rg",
            "description": "<p>Registro geral do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_nascimento",
            "description": "<p>Data de nascimento do associado. Mascara: 99/99/9999.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone",
            "description": "<p>Número de telefone do associado. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "celular",
            "description": "<p>Número de celular do associado. . Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_celular_aux",
            "description": "<p>Número de celular auxiliar do associado. . Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>e-Mail do associado. .</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro residêncial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número residêncial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento residêncial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro residêncial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade residêncial do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado residêncial do associado. Informar DESCRIÇÃO ou SIGLA.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep residêncial do associado. Mascara: 99999-999 ou 99.999-999 ou somente números.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_profissao",
            "description": "<p>Código profissão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_regional",
            "description": "<p>Código regional.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_conta",
            "description": "<p>Código do banco. Obrigatório caso tenha mais de uma conta bancária cadastrada para a regional.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "dia_vencimento",
            "description": "<p>Dia do mês no qual o boleto irá vencer.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_externo",
            "description": "<p>Código externo do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "sexo",
            "description": "<p>Sexo do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "boleto_fisico",
            "description": "<p>Boleto físico. Mascara: Y ou N</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "receber_whatsapp",
            "description": "<p>Receber whatsapp. Mascara: Y ou N</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_habilitacao",
            "description": "<p>Data de Vencimento da habilitação do associado. . Mascara: 99/99/9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_primeira_habilitacao",
            "description": "<p>Data de emissão da primeira habilitação do associado. . Mascara: 99/99/9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "categoria_cnh",
            "description": "<p>Categoria da CNH do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_como_conheceu",
            "description": "<p>Código da mídia pela qual o associado conheceu a associação.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "cartao",
            "description": "<p>Array contendo os atributos do cartão do associado. Contém os atributos: codigo_cartao(código do cartão do associado),  hash(hash do cartão), numero_final_cartao(últimos 3 dígitos do cartão)</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_cobranca_recorrente",
            "description": "<p>Código do tipo de cobrança recorrente. <br>Lista de tipo cobranca recorrente {<a href=\"#api-Boleto-Listar_tipo_cobran_a_recorrente\">aqui</a>}.</p>"
          }
        ]
      }
    },
    "success": {
