          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "ano_fabricacao",
            "description": "<p>Ano fabricação do veículo. Mascara: 9999</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "ano_modelo",
            "description": "<p>Ano modelo do veículo. Mascara: 9999</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_tipo_veiculo",
            "description": "<p>Código do tipo de veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "kilometragem",
            "description": "<p>Kilometagem do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "chassi",
            "description": "<p>Chassi do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "numero_motor",
            "description": "<p>Número motor do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "codigo_fipe",
