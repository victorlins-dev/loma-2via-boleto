        "content": "listar/vencimento/ativo",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_vencimento\": \"9\",\n\t\"dia_vencimento\": \"10\",\n\t\"situacao\": \"ATIVO\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classBeneficiario.php",
    "groupTitle": "Beneficiario",
