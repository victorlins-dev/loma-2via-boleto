  {
    "type": "post",
    "url": "historico-atendimento-associado/foto/cadastrar",
    "title": "Cadastrar foto/documento",
    "description": "<p>Adiciona fotos/documentos ao atendimento. A foto/documento pode ser enviada como uma URL ou um arquivo binário. Limite de 50 fotos por requição.<br><br>Formatos aceitos: .png, .jpeg, .jpg, .pdf;</p>",
    "name": "Cadastrar_Foto_documento",
    "version": "2.0.0",
    "group": "Atendimento",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_atedimento",
            "description": "<p>Código do atendimento ao qual a foto/documentos deve ser vinculada.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "foto",
            "description": "<p>Array contendo os índices: <br><code>nome_arquivo</code><br> <code>binario</code><br> <code>link</code><br> Observação:<br> Limite de 50 fotos por requisiçao;<br> Observe que na primeira posição do vetor &quot;foto&quot;, do exemplo de requisição, o índice &quot;link&quot; está preenchido e não foi colocado o índice &quot;binario&quot; não foi passado, pois a imagem foi passada como uma URL</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "foto.nome_arquivo",
            "description": "<p>Nome como o arquivo será salvo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "foto.link",
            "description": "<p>URL da imagem.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "foto.binario",
            "description": "<p>Arquivo binário da imagem.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_atendimento\" : 999,\n\t\"foto\" : [\n\t\t{\n\t\t\t\"nome_arquivo\" : \"imagem.png\",\n\t\t\t\"link\" : \"http://hinova.com.br/wp-content/uploads/2016/08/Hinova-Logo.png\"\n\t\t},\n\t\t{\n\t\t\t\"nome_arquivo\" : \"foto.jpg\",\n\t\t\t\"binario\" : \"iVBORw0KGgoAAAANSUhEUgAAA1IAAAI2CAIAAADVVi6oAAAKQ2lDQ1BJQ0MgcHJvZmlsZQAAeNqd U3dYk/cWPt/3ZQ9WQtjwsZdsgQAiI6wIyBBZohCSAGGEEBJAxYWIClYUFRGcSFXEgtUKSJ2I4qAouG\"\n\t\t}\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"nome_arquivo\": \"imagem.png\",\n\t\t\"situacao\": \"Inserido\"\n\t},\n\t{\n\t\t\"nome_arquivo\": \"foto.png\",\n\t\t\"situacao\": \"Inserido\"\n\t}\n]",
          "type": "json"
        }
      ]
    },
    "filename": "class/classAtendimento.php",
    "groupTitle": "Atendimento",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
