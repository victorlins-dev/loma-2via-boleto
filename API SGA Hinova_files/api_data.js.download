    "type": "post",
    "url": "/beneficiario/vincular-beneficio",
    "title": "Vincular",
    "description": "<p>Vincular uma lista de benefícios ao beneficiário de acordo com o array de benefícios</p>",
    "name": "Vincular_Beneficio",
    "version": "2.0.0",
    "group": "Beneficio",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
