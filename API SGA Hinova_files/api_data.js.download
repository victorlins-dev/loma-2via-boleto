  {
    "type": "get",
    "url": "listar/acionamento-fornecedor/:inicio_paginacao/:quantidade_por_pagina",
    "title": "Listar Acionamento Fornecedor",
    "description": "<p>Lista o acionamento fornecedor.</p>",
    "name": "Listar_Acionamento_fornecedor",
    "version": "2.0.0",
    "group": "Fornecedor",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "allowedValues": [
              "0",
              "1",
              "2",
              "3..."
            ],
            "optional": false,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Inicia apartir de 0 e deve ser acrescentado de 1 em 1 para navegar através das proximas páginas.<br>Caso não seja enviado, a lista irá começar pelo primeiro item do retorno.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "listar/acionamento-fornecedor/1/10",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição:",
        "content": "curl --request GET \\\n  --url https://api.hinova.com.br/api/sga/v2/listar/acionamento-fornecedor/1/10 \\\n  --header 'Authorization: Bearer token'",
        "type": "cURL"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"codigo\": \"9\",\n\t\t\"codigo_veiculo\": \"9\",\n\t\t\"codigo_associado\": \"9\",\n\t\t\"codigo_fornecedor\": \"9\",\n\t\t\"protocolo\": \"9\",\n\t\t\"produto\": \"PRODUTO\",\n\t\t\"servico\": \"SERVICO\",\n\t\t\"motivo\": \"MOTIVO\",\n\t\t\"situacao\": \"SITUACAO\",\n\t\t\"data_acionamento\": \"yyyy-mm-dd\",\n\t\t\"hora_acionamento\": \"00:00:00\",\n\t\t\"data_conclusao_acionamento\": \"yyyy-mm-dd\",\n\t\t\"hora_conclusao_acionamento\": \"00:00:00\",\n\t\t\"data_ocorrencia\": \"yyyy-mm-dd\",\n\t\t\"hora_ocorrencia\": \"00:00:00\"\n\t}\n]",
          "type": "json"
        }
      ]
    },
    "filename": "class/classFornecedor.php",
    "groupTitle": "Fornecedor",
    "header": {
      "fields": {
        "Header": [
