          "content": "{\n\t\"codigo_banco\": \"9\",\n\t\"data_pagamento_inicial\": \"99/99/9999\",\n\t\"data_pagamento_final\": \"99/99/9999\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_situacao_boleto\": \"9\",\n\t\"data_vencimento_inicial\": \"99/99/9999\",\n\t\"data_vencimento_final\": \"99/99/9999\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n  \"mostrando \": 100,\n  \"numero_paginas\": 10,\n  \"total_registros\": \"3000\",\n  \"pagina_corrente\": 1,\n  \"boletos\": [\n    {\n      \"nosso_numero\": 999999,\n      \"linha_digitavel\": \"9999.999999 999999.999999 9999.99999 9 9999999999\",\n      \"valor_boleto\": \"99.99\",\n      \"valor_pagamento\": \"0.00\",\n      \"codigo_tipo_boleto\": \"9\",\n      \"tipo_boleto\": \"A-Z\",\n      \"codigo_associado\": 99999,\n      \"nome_associado\": \"A-Z\",\n      \"cpf\": \"99999999999\",\n      \"telefone_fixo\": \"(99) 9999-9999\",\n      \"celular\": \"(99) 9999-9999\",\n      \"telefone_comercial\": \"(99) 9999-9999\",\n      \"email\": \"email@email.com\",\n      \"email_auxiliar\": \"email@email.com\",\n      \"data_inicio_contrato_associado\": \"dd/mm/yyyy\",\n      \"data_fim_contrato_associado\": \"dd/mm/yyyy\",\n      \"data_emissao\": \"dd/mm/yyyy\",\n      \"data_vencimento\": \"dd/mm/yyyy\",\n      \"data_vencimento_original\": \"dd/mm/yyyy\",\n      \"data_pagamento\": \"dd/mm/yyyy\",\n      \"codigo_situacao_boleto\": \"9\",\n      \"situacao_boleto\": \"A-Z\",\n      \"codigo_banco\": \"9\",\n      \"mes_referente\": \"mm/yyyy\",\n\t  \"codigo_mgfformapagamento\": \"1\",\n      \"veiculos\": [\n        {\n          \"codigo_veiculo\": 99999,\n          \"codigo_tipo_veiculo\": \"9\",\n          \"codigo_regional\": \"9\",\n          \"codigo_voluntario\": \"9\",\n          \"placa\": \"A-Z\",\n          \"chassi\": \"A-Z\",\n          \"renavam\": \"A-Z\",\n          \"codigo_fipe\": \"999999-9\",\n          \"modelo\": \"A-Z\",\n          \"ano_modelo\": \"yyyy\",\n          \"marca\": \"A-Z\",\n          \"valor_protegido\": \"999999,99\",\n          \"valor_fipe\": \"99999,99\",\n          \"valor_adesao\": \"9,99\",\n          \"data_inicio_contrato_veiculo\": \"dd/mm/yyyy\",\n          \"data_fim_contrato_veiculo\": \"dd/mm/yyyy\",\n          \"codigo_tipo_envio_boleto\": \"9\",\n          \"descricao_tipo_envio_boleto\": \"A-Z\",\n          \"situacao_veiculo\": \"A-Z\",\n          \"total_taxas_produtos\": \"999.99\",\n          \"total_taxas\": \"99,99\",\n          \"taxas\": [\n            {\n                \"codigo_classificacaoproduto\": 9,,\n                \"descricao_taxa\": \"A-Z\",\n                \"valor_taxa\": \"99.99\"\n            },\n            {\n                \"codigo_classificacaoproduto\": 9,,\n                \"descricao_taxa\": \"A-Z\",\n                \"valor_taxa\": \"99.99\"\n            },\n            {\n                \"codigo_classificacaoproduto\": 9,,\n                \"descricao_taxa\": \"A-Z\",\n                \"valor_taxa\": \"99.99\"\n            },\n            {\n                \"codigo_classificacaoproduto\": 9,\n                \"descricao_taxa\": \"A-Z\",\n                \"valor_taxa\": \"99.99\"\n            }\n          ]\n        }\n      ]\n    }\n}",
          "type": "json"
