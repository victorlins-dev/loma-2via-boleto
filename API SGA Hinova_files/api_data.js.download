  {
    "type": "get",
    "url": "listar/produto-por-situacao/:situacao",
    "title": "Listar Por Situação",
    "name": "Listar_Produto_por_situa__o",
    "description": "<p>Lista todos os produtos que estão dentro da situação enviada respeitando as permissões de cooperativa e regional do usuário. Este método não usa os filtros específicos: Regional, Cooperativa, Tipo veículo, Valor Fipe e Cilindrada. Estes filtros são utilizados no método listar/produto</p>",
    "version": "2.0.0",
    "group": "Produto",
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "/listar/produto-por-situacao/ativo",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_produto\": \"9999\",\n\t\"descricao_produto\": \"ASSISTÊNCIA 24 HORAS\",\n\t\"codigo_fornecedor\": \"99\",\n\t\"codigo_classificacaoproduto\": \"99\",\n\t\"descricao_produto_boleto\": \"ASSISTÊNCIA\",\n\t\"tipo_veiculo\": \"9\",\n\t\"descricao_tipo_veiculo\" : \"AUTOMÓVEL\",\n\t\"valor_produto\": \"999,99\",\n\t\"valor_fipe_inicial\": 9,\n\t\"valor_fipe_final\": 99999,\n\t\"padrao\": \"Y\",\n\t\"formato_cobranca\" : \"R$\",\n\t\"situacao\" : \"ATIVO\",\n\t\"cooperativas\": [\n\t\t{\n\t\t\t\"codigo_cooperativa\": 7,\n\t\t\t\"nome\": \"CAMILA OBICI\"\n\t\t}\n\t],\n\t\"regionais\": [\n\t\t{\n\t\t\t\"codigo_regional\": 1,\n\t\t\t\"nome\": \"HINOVA SOLUÇÕES DIGITAIS - APRECIAÇÃO\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classProduto.php",
    "groupTitle": "Produto",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    },
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "ativo",
              "inativo",
              "todos"
            ],
            "optional": false,
            "field": "situacao",
            "description": "<p>Define qual a situação dos objetos a serem retornados.</br><code>todos</code>: retorna ativos e inativos.</br><code>ativo</code>: retorna apenas ativos.</br><code>inativo</code>: retorna apenas inativos.</p>"
          }
        ]
      }
    }
  },
