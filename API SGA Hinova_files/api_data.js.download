  {
    "type": "post",
    "url": "/listar/boleto-associado-veiculo",
    "title": "Listar por associado/veículo",
    "description": "<p>Lista todos os boletos de um associado ou veículo em um determinado intervalo de tempo, sendo obrigatório enviar o código ou cpf do associado ou o código ou placa do veículo e ao menos um par de data inicial e final. O limite do intervalo de tempo é de, no máximo, 90 dias</p>",
    "name": "Listar_Boleto_Associado_veiculo",
    "version": "2.0.0",
    "group": "Boleto",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado ao qual os boletos estão vinculados</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo ao qual os boletos estão vinculados</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpf_associado",
            "description": "<p>CPF do associado ao qual os boletos estão vinculados</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "placa",
            "description": "<p>Placa do veículo ao qual os boletos estão vinculados</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_situacao_boleto",
            "description": "<p>Código da situação dos boletos a serem retornados</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_inicial",
            "description": "<p>Data inicial do vencimento dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_final",
            "description": "<p>Data final do vencimento dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_original_inicial",
            "description": "<p>Data inicial do vencimento original dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_vencimento_original_final",
            "description": "<p>Data final do vencimento original dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_pagamento_inicial",
            "description": "<p>Data inicial do pagamento dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_pagamento_finalww",
            "description": "<p>Data final do pagamento dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao_inicial",
            "description": "<p>Data inicial da emissão dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao_final",
            "description": "<p>Data final da emissão dos boletos a serem retornados.</p>"
          },
          {
            "group": "Parameter",
            "type": "bool",
            "optional": true,
            "field": "link_boleto",
            "description": "<p>Retorna o link do boleto.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"placa\" : \"AAA-9999\",\n\t\"data_vencimento_original_inicial\": \"99/99/9999\",\n\t\"data_vencimento_original_final\": \"99/99/9999\",\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"cpf_associado\": \"123.454.457.99\",\n\t\"data_emissao_inicial\": \"99/99/9999\",\n\t\"data_emissao_final\": \"99/99/9999\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_associado\": \"9\",\n\t\"data_pagamento_inicial\": \"99/99/9999\",\n\t\"data_pagamento_final\": \"99/99/9999\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_veiculo\": \"9\",\n\t\"codigo_situacao_boleto\": \"9\",\n\t\"data_vencimento_inicial\": \"99/99/9999\",\n\t\"data_vencimento_final\": \"99/99/9999\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"nosso_numero\": 9999,\n\t\"linha_digitavel\": \"99999.99999 999999.99999 99999.999999 9 9999999999\",\n\t\"codigo_tipo_boleto\": \"9\",\n\t\"tipo_boleto\": \"FECHAMENTO\",\n\t\"valor_boleto\": \"999.99\",\n\t\"valor_multa\": \"9.999\",\n\t\"valor_mora\": \"9.9\",\n\t\"valor_boleto_multa_mora\": \"999.99\",\n\t\"quantidade_dias_vencidos\": 99,\n\t\"codigo_associado\": 999,\n\t\"nome_associado\": \"HINOVA SOLUÇÕES DIGITAIS\",\n\t\"cpf\": \"99999999\",\n\t\"telefone_fixo\": \"(99) 99999-9999\",\n\t\"celular\": \"(99) 99999-9999\",\n\t\"telefone_comercial\": \"(99) 9999-9999\",\n\t\"email\": \"hinova@hinova.com.br\",\n\t\"email_auxiliar\": \"hinova.aux@hinova.com\",\n\t\"data_inicio_contrato_associado\": \"yyyy-mm-dd\",\n\t\"data_fim_contrato_associado\": \"yyyy-mm-dd\",\n\t\"data_emissao\": \"yyyy-mm-dd\",\n\t\"data_vencimento\": \"yyyy-mm-dd\",\n\t\"data_vencimento_original\": \"yyyy-mm-dd\",\n\t\"data_pagamento\":\"yyyy-mm-dd\",\n\t\"codigo_situacao_boleto\": \"9\",\n\t\"situacao_boleto\": \"ABERTO\",\n\t\"codigo_mgfformapagamento\": \"1\",\n\t\"pix\" : {\n\t\t\"qrcode\" : \"QRCODE EM HASH BASE64\",\n\t\t\"copia_cola\" \"STRING DO PIX COPIA E COLA\": \n\t}\n\t\"veiculos\": [\n\t\t{\n\t\t\t\"codigo_veiculo\": 999,\n\t\t\t\"codigo_tipo_veiculo\": \"9\",\n\t\t\t\"codigo_regional\": \"9\",\n\t\t\t\"placa\": \"AAA1111\",\n\t\t\t\"chassi\": \"9999999999\",\n\t\t\t\"renavam\": \"99999\",\n\t\t\t\"codigo_fipe\": \"99999-9\",\n\t\t\t\"modelo\": \"MODELO VEíCULO\",\n\t\t\t\"ano_modelo\": \"yyyy\",\n\t\t\t\"marca\": \"MARCA VEíCULO\",\n\t\t\t\"valor_protegido\": \"9999,99\",\n\t\t\t\"valor_fipe\": \"9999,99\",\n\t\t\t\"valor_adesao\": \"99,99\",\n\t\t\t\"data_inicio_contrato_veiculo\": \"yyyy-mm-dd\",\n\t\t\t\"data_fim_contrato_veiculo\": \"yyyy-mm-dd\",\n\t\t\t\"situacao_veiculo\": \"PENDENTE\",\n\t\t\t\"total_taxas_produtos\": 99,\n\t\t\t\"total_taxas\": \"99,99\",\n\t\t\t\"taxas\": [\n\t\t\t\t{\n\t\t\t\t\t\"descricao_taxa\": \"EXEMPLO DE DESCRIçãO\",\n\t\t\t\t\t\"valor_taxa\": \"99,99\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t]\n}",
