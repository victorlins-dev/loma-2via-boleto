  {
    "type": "post",
    "url": "/voluntario/cadastrar",
    "title": "Cadastrar",
    "description": "<p>Cadastra um novo voluntário, se o CPF do voluntário for igual a um existente na base, esse voluntário será alterado com os dados enviados na requisição.<br> Quando um voluntário é alterado pelo método de cadastrar voluntário, não é possível alterar as cooperativas às quais ele está atrelado,<br> Para alterar as cooperativas será preciso utilizar um método específico para isso.</p>",
    "name": "Cadastrar",
    "version": "2.0.0",
    "group": "Voluntario",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "nome",
            "description": "<p>Nome do voluntário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpf",
            "description": "<p>CPF do voluntário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "formato_pagamento",
            "description": "<p>Formato de pagamento do voluntário(R ou %)</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_pagamento",
            "description": "<p>Valor do pagamento do voluntário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone",
            "description": "<p>Telefone do voluntário. Mascara &quot;(99) 99999-9999&quot;, &quot;99999999999&quot;.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "cooperativas",
            "description": "<p>Array contendo o código das cooperativas que o voluntário estará atrelado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "celular",
            "description": "<p>Telefone celular do voluntário. Mascara &quot;(99) 99999-9999&quot;, &quot;99999999999&quot;.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_comercial",
            "description": "<p>Telefone comercial do voluntário. Mascara &quot;(99) 99999-9999&quot;, &quot;99999999999&quot;.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_classificacao",
            "description": "<p>Código da classificação do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero",
            "description": "<p>Número da residência do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>complemento da residência do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>CEP do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>E-mail do voluntário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "obs",
            "description": "<p>Observações.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "radio",
            "description": "<p>id radio.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "radio_auxiliar",
            "description": "<p>id radio auxiliar.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_voluntario_vinculado",
            "description": "<p>codigo do voluntario indicação.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_classificacao\"\t: 9,\n\t\"nome\" : \"Hinova Soluções Digitais\",\n\t\"cpf\" : \"999.999.999-99\",\n\t\"celular\" : \"(99)99999-9999\",\n\t\"telefone_comercial\" : \"(99)9999-9999\",\n\t\"formato_pagamento\" : \"R\",\n\t\"valor_pagamento\" : \"999,00\",\n\t\"logradouro\" : \"logradouro\",\n\t\"numero\" : \"9\",\n\t\"complemento\" : \"bloco 9\",\n\t\"bairro\" : \"bairro\",\n\t\"cidade\" : \"BH\",\n\t\"estado\" : \"MG\",\n\t\"cep\" : \"99999999\",\n\t\"email\" : \"hinova@hinova.com.br\",\n\t\"obs\" : \"observações\",\n\t\"cooperativas\" : [\n\t\t{\n\t\t\t\"codigo_cooperativa\" : \"9\"\n\t\t},\n\t\t{\n\t\t\t\"codigo_cooperativa\" : \"99\"\n\t\t},\n\t\t{\n\t\t\t\"codigo_cooperativa\" : \"999\"\n\t\t}\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
