  {
    "type": "get",
    "url": "/listar/categoria-veiculo/:codigo_tipo/:situacao",
    "title": "Listar categoria",
    "description": "<p>Lista as categorias disponíveis de acordo com o tipo do veículo e a situação desejada, esta situação pode ser: Ativo, Inativo ou Todos. Deve ser passado também o código do tipo do veículo Obs: A situação e o tipo são obrigatórios</p>",
    "name": "Listar_Categoria_Veiculo",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "codigo_tipo",
            "description": "<p>Define o tipo do veículo, como cada categoria está atrelada a um tipo de veículo, só serão retornadas categorias que estejam associadas ao tipo de veículo definido</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "ativo",
              "inativo",
              "todos"
            ],
            "optional": false,
            "field": "situacao",
            "description": "<p>Define qual a situação dos objetos a serem retornados.</br><code>todos</code>: retorna ativos e inativos.</br><code>ativo</code>: retorna apenas ativos.</br><code>inativo</code>: retorna apenas inativos.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "/listar/categoria-veiculo/9/ativo",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"codigo_categoria\": \"9\",\n\t\"descricao_categoria\": \"PASSEIO\",\n\t\"codigo_tipo_veiculo\": \"99\",\n\t\"situacao\": \"ATIVO\",\n\t\"valor_adesao\": \"0.00\",\n\t\"participacao_minima\": \"0.00\",\n\t\"porcentagem_fipe\": \"0.00\"\n}",
          "type": "json"
        }
      ]
    },
