  {
    "type": "post",
    "url": "mgf-lancamento/cadastrar",
    "title": "Cadastrar Lançamento",
    "name": "Cadastrar_lan_amento",
    "description": "<p>Cadastra um lançamento no MGF</p>",
    "version": "2.0.0",
    "group": "MGF",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_nota_fiscal",
            "description": "<p>Data da Nota Fiscal. Formato dd/mm/yyyy</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "valor_nota_fiscal",
            "description": "<p>Valor da Nota Fiscal.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_operacao",
            "description": "<p>Código da operação do lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_suboperacao",
            "description": "<p>Código da sub-operações do lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_descricao",
            "description": "<p>Código da descrição do lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero_nota_fiscal",
            "description": "<p>Número da Nota FIscal.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_banco",
            "description": "<p>Código do banco do lançamento. Necessário enviar código banco ou código caixa local</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_caixa_local",
            "description": "<p>Código do caixa local do lançamento. Necessário enviar código banco ou código caixa local</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_evento",
            "description": "<p>Código do evento que será vinculado ao lançamento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "parcelas",
            "description": "<p>Array contendo os índices: <br> <code>codigo_situacao_parcela</code><br> <code>valor_parcela</code>(valor da parcela. Formato &quot;99,99&quot;)<br> <code>data_vencimento</code>(data de vencimento da parcela. Formato &quot;dd/mm/yyyy&quot;) <code>data_pagamento</code>(Data do pagamento da parcela. Formato &quot;dd/mm/yyyy&quot;, opcional. Deve ser enviado quando cadastrado uma parcela na situação PAGA)</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"data_nota_fiscal\" : \"dd/mm/yyyy\",\n    \"numero_nota_fiscal\" : \"999999\",\n    \"valor_nota_fiscal\" : \"99,99\",\n    \"codigo_operacao\" : \"9\",\n    \"codigo_suboperacao\" : \"99\",\n    \"codigo_descricao\" : \"99\",\n    \"codigo_caixa_local\" : 9,\n    \"codigo_forma_pagamento\" : 9,\n    \"parcelas\" :[\n        {\n            \"codigo_situacao_parcela\" : 9,\n            \"valor_parcela\" : \"99,99\",\n            \"data_vencimento\" : \"dd/mm/yyyy\"\n\n        },\n        {\n            \"codigo_situacao_parcela\" : 1,\n            \"valor_parcela\" : \"99,99\",\n            \"data_vencimento\" : \"dd/mm/yyyy\"\n            \"data_pagamento\" : \"dd/mm/yyyy\",\n        }\n    ]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n    \"mensagem\": \"OK\",\n    \"codigo_lancamento\": \"9\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classMgf.php",
    "groupTitle": "MGF",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
