  {
    "type": "get",
    "url": "listar/conta/:situacao",
    "title": "Listar Contas Bancárias",
    "name": "Listar_Conta_Banc_ria",
    "description": "<p>Lista as contas as quais o usuário tem permissão de acesso</p>",
