  {
    "type": "post",
    "url": "listar/vistoria",
    "title": "Listar vistoria",
    "description": "<p>Lista as vistorias</p>",
    "name": "Listar_vistoria",
    "version": "2.0.0",
    "group": "Vistoria",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_vistoria_inicial",
            "description": "<p>Data de vistoria inicial</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_vistoria_final",
            "description": "<p>Data de vistoria final</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo",
            "description": "<p>Código do veiculo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_associado",
            "description": "<p>Código do associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_vistoriador",
            "description": "<p>Código do vistoriador.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "allowedValues": [
              "0",
              "1",
              "2",
              "3..."
            ],
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Inicia apartir de 0 e deve ser acrescentado de 1 em 1 para navegar através das proximas páginas.<br>Caso não seja enviado, a lista irá começar pelo primeiro item do retorno.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"data_vistoria_inicial\": \"99/99/9999\",\n    \"data_vistoria_final\": \"99/99/9999\",\n    \"codigo_veiculo\":\"999\",\n    \"codigo_associado\":\"999\",\n    \"codigo_vistoriador\":\"999\",\n    \"inicio_paginacao\": 0,\n    \"quantidade_por_pagina\":\"100\"\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "\"total\": \"99\",\n\"numero_paginas\": 1,\n\"mostrando\": 9,\n\"pagina_corrente\": 0,\n\"retorno\": [\n    {\n        \"codigo_vistoria\": 65,\n        \"codigo_associado\": 3,\n        \"codigo_veiculo\": 2543,\n        \"codigo_veiculo_provisorio\": null,\n        \"codigo_tipo_vistoria\": 7,\n        \"codigo_tipo_local\": null,\n        \"nome_usuario\": \"HINOVA SOLUÇÕES DIGITAIS\",\n        \"codigo_imagem_vistoria\": 2,\n        \"codigo_marca_pneu\": 170,\n        \"codigo_medida_pneu\": 11,\n        \"codigo_estado_pneu\": 2,\n        \"valor_vistoria\": \"0.00\",\n        \"latitude\": null,\n        \"longitude\": null,\n        \"observacao\": \"TESTE\",\n        \"data_vistoria\": \"9999-99-99\",\n        \"data_recebimento_vistoria\": \"9999-99-99\",\n        \"codigo_vistoriador\": \"9999\",\n        \"nome_vistoriador\": \"NOME\",\n        \"data_ocorrencia\": \"2021-10-18\",\n        \"hora_ocorrencia\": \"15:01:02\",\n        \"item_vistoria\": [\n            {\n                \"item\": \"AEROFÓLIO\",\n                \"tipo_avaria\": \"QUEBRADO\"\n            },\n            {\n                \"item\": \"BANCO DE COURO\",\n                \"tipo_avaria\": \"QUEBRADO\"\n            }\n        ]\n    }",
          "type": "json"
        }
      ]
    },
    "filename": "class/classVistoria.php",
    "groupTitle": "Vistoria",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
