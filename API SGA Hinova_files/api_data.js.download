          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado ao qual o beneficiário está vinculado. Obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone",
            "description": "<p>Número de telefone do beneficiário. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_parentesco",
            "description": "<p>Código do parentesco do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "celular",
            "description": "<p>Número de celular do beneficiário. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "email",
            "description": "<p>e-Mail do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_profissao",
            "description": "<p>Código profissão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "dia_vencimento",
            "description": "<p>Dia do mês no qual o boleto irá vencer.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_externo",
            "description": "<p>Código externo do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "sexo",
            "description": "<p>Sexo do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "categoria_cnh",
            "description": "<p>Categoria da CNH do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "qtde_parcela_carne",
            "description": "<p>Quantidade de parcelas do carnê.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fixo",
            "description": "<p>Valor Fixo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "gerar_cobranca",
            "description": "<p>Especifica se deve ser gerada cobrança para o beneficiário sendo cadastrado. Deve ser enviada no formato &quot;Y&quot;(sim) ou &quot;N&quot;(não)</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "beneficios",
            "description": "<p>Array contendo os códigos dos benefícios a serem vinculados ao beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ddd_radio",
