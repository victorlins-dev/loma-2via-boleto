          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "logradouro",
            "description": "<p>Logradouro residêncial do beneficiário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "numero",
            "description": "<p>Número residêncial do beneficiário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "complemento",
            "description": "<p>Complemento residêncial do beneficiário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "bairro",
            "description": "<p>Bairro residêncial do beneficiário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cidade",
            "description": "<p>Cidade residêncial do beneficiário</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "estado",
            "description": "<p>Estado residêncial do beneficiário. Informar DESCRIÇÃO ou SIGLA</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cep",
            "description": "<p>Cep residêncial do beneficiário. Mascara: 99999-999 ou 99.999-999 ou somente números</p>"
