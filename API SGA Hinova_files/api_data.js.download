            "field": "renavam",
            "description": "<p>Renavam do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa. Será selecionado de acordo com a permissão do usuário</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_externo",
            "description": "<p>Código externo do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_modelo",
            "description": "<p>Código do Modelo do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "placa",
            "description": "<p>Placa do veículo. Caso o veículo seja ZERO KM não necessário enviar ou enviar vazio</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "cilindrada",
            "description": "<p>Cilindrada do veículo. Utilizado quando o item é motocicleta.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_portas",
            "description": "<p>Quantidade de portas do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cambio",
