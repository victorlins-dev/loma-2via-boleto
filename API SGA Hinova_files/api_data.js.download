          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigo_beneficiario",
            "description": "<p>Código do beneficiário inserido na base de dados</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "    \t{\n    \t\t\"nome\"\t\t\t\t: \"Hinova Soluções Digitais\",\n     \t\t\"codigo_beneficiario\" : 999,\n      \t\"telefone\"\t\t\t: \"(99) 99999-9999\",\n      \t\"celular\"\t\t\t: \"(99) 99999-9999\",\n      \t\"email\"\t\t\t\t: \"teste@hinova.com.br\",\n       \t\"logradouro\"\t\t: \"Rua Manoel Elias de Aguiar\",\n        \t\"numero\"\t\t\t: \"245\",\n         \t\"complemento\"\t\t: \"Comercial\",\n          \"bairro\"\t\t\t: \"Ouro Preto\",\n          \"cidade\"\t\t\t: \"Belo Horizonte\",\n          \"estado\"\t\t\t: \"Minas Gerais\",\n          \"cep\"\t\t\t\t: \"31.330-520\",\n\t\t\t\"dia_vencimento\"\t: 99\n      }",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n  \t\"codigo\"\t\t\t\t: \t\"200\",\n   \t\"mensagem\"\t\t\t\t: \t\"OK\",\n   \t\"codigo_beneficiario\"\t:\t999\n}",
          "type": "json"
        }
      ]
