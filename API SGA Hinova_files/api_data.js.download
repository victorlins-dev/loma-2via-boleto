            "type": "String",
            "optional": false,
            "field": "telefone",
            "description": "<p>Número de telefone da regional. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "email",
            "description": "<p>e-Mail da regional.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "website",
            "description": "<p>Website da regional.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigo_regional",
            "description": "<p>Código da regional inserido na base de dados</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n    \"nome\"              :   \"Hinova Soluções Digitais\",\n    \"nome_fantasia\"     :   \"Hinova\",\n    \"cnpj\"              :   \"99.999.999/9999-99\",\n    \"logradouro\"        :   \"Rua Manoel Elias de Aguiar\",\n    \"numero\"            :   \"245\",\n    \"complemento\"       :   \"Comercial\",\n    \"bairro\"            :   \"Ouro Preto\",\n    \"cidade\"            :   \"Belo Horizonte\",\n    \"estado\"            :   \"Minas Gerais\",\n    \"cep\"               :   \"31.330-520\",\n    \"telefone\"          :   \"(99) 99999-9999\",\n    \"email\"             :   \"teste@hinova.com.br\",\n    \"website\"           :   \"https://www.hinova.com.br/\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n    \"mensagem\"          :   \"OK\",\n    \"codigo_regional\"  :   999999\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classRegional.php",
    "groupTitle": "Regional",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
  },
  {
    "type": "get",
    "url": "listar/regional/:situacao",
    "title": "Listar",
    "description": "<p>Lista as regionais disponíveis de acordo com a situação desejada, esta situação pode ser: Ativo, Inativo ou Todos. Obs: A situação é obrigatória</p>",
    "name": "Listar_Regional",
    "version": "2.0.0",
    "group": "Regional",
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "listar/regional/ativo",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n    \"codigo_regional\": 9,\n    \"descricao_regional\": \"Hinova Soluções Digitais\",\n    \"situacao\": \"ATIVO\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classRegional.php",
    "groupTitle": "Regional",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    },
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "ativo",
              "inativo",
              "todos"
            ],
            "optional": false,
            "field": "situacao",
            "description": "<p>Define qual a situação dos objetos a serem retornados.</br><code>todos</code>: retorna ativos e inativos.</br><code>ativo</code>: retorna apenas ativos.</br><code>inativo</code>: retorna apenas inativos.</p>"
          }
        ]
      }
    }
  },
  {
    "type": "post",
    "url": "termo/emitir",
    "title": "Emitir",
    "name": "Emitir_Termo",
    "description": "<p>Emite um termo.</p>",
    "version": "2.0.0",
    "group": "Termo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_termo",
            "description": "<p>Código do termo a ser emitido.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_associado",
            "description": "<p>Código do associado vinculado ao termo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_beneficiario",
            "description": "<p>Código do beneficiário vinculado ao termo (Obrigatório caso seja um termo de beneficiário).</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo vinculado ao termo (Obrigatório caso seja um termo de veículo).</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_evento",
            "description": "<p>Código do evento vinculado ao termo (Obrigatório caso seja um termo de evento).</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ferramenta",
            "description": "<p>Obrigatorio somente caso o endpoint termo/listar retorne esta posição com o valor NOVOTERMO.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição (Termo de Veículo)",
        "content": "{\n\t\"codigo_termo\": \"99\",\n\t\"codigo_associado\": \"99\",\n\t\"codigo_veiculo\": \"99\",\n}",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição (Termo de Beneficiário)",
        "content": "{\n\t\"codigo_termo\": \"99\",\n\t\"codigo_associado\": \"99\",\n\t\"codigo_beneficiario\": \"99\",\n}",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição (Termo de Evento)",
        "content": "{\n\t\"codigo_termo\": \"99\",\n\t\"codigo_associado\": \"99\",\n\t\"codigo_veiculo\": \"99\",\n\t\"codigo_evento\": \"99\"\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno",
          "content": "{\n\t\"codigo_emissao\": \"99\",\n\t\"link_pdf\": \"https:\\/\\/short.hinova.com.br\\/v2\\/111111\"\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classTermo.php",
    "groupTitle": "Termo",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
