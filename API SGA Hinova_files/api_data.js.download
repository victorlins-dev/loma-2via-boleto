              "\"ano_modelo\"",
              "\"codigo_tipo_veiculo\"",
              "\"km\"",
              "\"chassi\"",
              "\"numero_motor\"",
              "\"codigo_fipe\"",
              "\"codigo_voluntario\"",
              "\"codigo_vencimento\"",
              "\"renavam\"",
              "\"codigo_cooperativa\"",
              "\"codigo_externo\"",
              "\"codigo_modelo\"",
              "\"placa\"",
              "\"cilindrada\"",
              "\"quantidade_portas\"",
              "\"cambio\"",
              "\"codigo_cota\"",
              "\"codigo_conta\"",
              "\"codigo_alienacao\"",
              "\"codigo_combustivel\"",
              "\"codigo_cor\"",
              "\"codigo_categoria\"",
              "\"logradouro\"",
              "\"numero\"",
              "\"complemento\"",
              "\"bairro\"",
              "\"cidade\"",
              "\"estado\"",
              "\"cep\"",
              "\"numero_nota\"",
              "\"data_emissao_nota\"",
              "\"data_contrato\"",
              "\"valor_adesao\"",
              "\"codigo_veiculo_indicacao\"",
              "\"forma_pagamento_adesao\"",
              "\"codigo_depreciacao\"",
              "\"valor_fipe\"",
              "\"valor_fixo\"",
              "\"porcentagem_fipe_protegido\"",
              "\"participacao\"",
              "\"codigo_tipo_envio_boleto\"",
              "\"quantidade_passageiros\"",
              "\"codigo_indicacao_externa\"",
              "\"valor_repasse\"",
              "\"forma_pagamento_repasse\"",
              "\"exibir_extrato_rateio\"",
              "\"gerar_cobranca_rateio\"",
              "\"codigo_tabela_avaliacao\"",
              "\"codigo_tipo_adesao\"",
              "\"produto_veiculo\""
            ],
            "optional": false,
            "field": "campos",
            "description": "<p>Array contendo o nome dos campos do veículo que devem ser retornados</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "allowedValues": [
              "0",
              "1",
              "2",
              "3..."
            ],
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Inicia apartir de 0 e deve ser acrescentado de 1 em 1 para navegar através das proximas páginas.<br>Caso não seja enviado, a lista irá começar pelo primeiro item do retorno.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"data_inicial\": \"dd/mm/yyyy\", \n\t\"data_final\": \"dd/mm/yyyy\",\n\t\"ultima_alteracao\": \"Y\",\n\t\"valor_anterior\": [1],\n\t\"valor_posterior\": [2],\n\t\"campos\": [\n\t\t\"codigo_situacao\",\n\t\t\"placa\",\n\t\t\"codigo_associado\"\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"codigo_alteracao\": \"999\",\n\t\t\"codigo_veiculo\": \"99\",\n\t\t\"placa\": \"AAA9999\",\n\t\t\"chassi\": \"99999999999999\",\n\t\t\"nome_campo_tabela\": \"placa\",\n\t\t\"valor_anterior\": \"BBB9999\",\n\t\t\"valor_posterior\": \"AAA9999\",\n\t\t\"data_alteracao\": \"2020-10-24T00:00:00-0300\",\n\t\t\"codigo_usuario_alteracao\": \"9\",\n\t\t\"nome_usuario_alteracao\": \"HINOVA SOLUÇÕES DIGITAIS\"\n\t}\n]",
          "type": "json"
        }
      ]
    },
