\",\n\t\t\t\"descricao_modelo\": \"MODELO\",\n\t\t\t\"codigo_modelo\": \"999\",\n\t\t\t\"codigo_veiculo_indicador\": 9,\n\t\t\t\"placa_veiculo_indicador\": 99,\n\t\t\t\"codigo_associado_indicador\": 9,\n\t\t\t\"cpf_associado_indicador\": 9,\n\t\t\t\"nome_associado_indicador\": 9\n\t\t}\n\t],\n\t\"beneficiario\": [\n\t\t{\n\t\t\t\"codigo_associado_beneficiario\": \"999\",\n\t\t\t\"dia_vencimento\": \"99\",\n\t\t\t\"codigo_tipo_cobranca_recorrente\": \"9\",\n\t\t\t\"descricao_tipo_cobranca_recorrente\": \"BOLETO\",\n\t\t\t\"codigo_cooperativa\": \"1\",\n\t\t\t\"codigo_voluntario\": \"1\",\n\t\t\t\"pontos\": 0,\n\t\t\t\"descricao_situacao\": \"ATIVO\",\n\t\t\t\"codigo_situacao\": \"1\"\n\t\t}\n\t]\n}",
