          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_radio",
            "description": "<p>Número de radio do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "ddd_radio_aux",
            "description": "<p>DDD do radio do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "telefone_radio_aux",
            "description": "<p>Número de radio do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "valor_adesao",
            "description": "<p>valor de adesao do beneficiário.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "Number",
            "optional": false,
            "field": "codigo",
            "description": "<p>Código de retorno. Ex: 200, 203, 401 etc</p>"
