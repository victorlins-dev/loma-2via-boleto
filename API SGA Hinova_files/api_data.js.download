            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
  },
  {
    "type": "post",
    "url": "/veiculo/foto/cadastrar",
    "title": "Cadastrar foto",
    "description": "<p>Adiciona fotos ao veículo, ao beneficiário ou para o evento, esse envio deve ser feito de forma separada, para um objeto de cada vez. A foto pode ser enviada como uma URL ou um arquivo binário. Limite de 50 fotos por requição.<br><br>Formatos aceitos: .png, .jpeg, .jpg, .pdf;</p>",
    "name": "Cadastrar_Foto",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo ao qual a foto deve ser vinculada.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_beneficiario",
            "description": "<p>Código do beneficiário ao qual a foto deve ser vinculada.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_evento",
            "description": "<p>Código do evento ao qual a foto deve ser vinculada. Caso se esteja enviando um código de evento é obrigatório mandar um código de veículo que esteja incluso no evento</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": false,
            "field": "foto",
            "description": "<p>Array contendo os índices: <br><code>nome_arquivo</code>(nome como o arquivo será salvo)<br> <code>codigo_tipo</code>(código do tipo da foto que está sendo inserida)<br> <code>binario</code>(arquivo binário da imagem)<br> <code>link</code>(URL da imagem)<br> Observação:<br> Limite de 50 fotos por requisiçao;<br> Observe que na primeira posição do vetor &quot;foto&quot;, do exemplo de requisição, o índice &quot;link&quot; está preenchido e não foi colocado o índice &quot;binario&quot; não foi passado, pois a imagem foi passada como uma URL</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_veiculo\" : 999,\n\t\"codigo_evento\" : 999,\n\t\"foto\" : [\n\t\t{\n\t\t\t\"nome_arquivo\" : \"imagem.png\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"link\" : \"http://hinova.com.br/wp-content/uploads/2016/08/Hinova-Logo.png\",\n\t\t\t\"observacao\" : \"foto com extensão .png passada por URL\"\n\t\t},\n\t\t{\n\t\t\t\"nome_arquivo\" : \"foto.jpg\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"binario\" : \"iVBORw0KGgoAAAANSUhEUgAAA1IAAAI2CAIAAADVVi6oAAAKQ2lDQ1BJQ0MgcHJvZmlsZQAAeNqd U3dYk/cWPt/3ZQ9WQtjwsZdsgQAiI6wIyBBZohCSAGGEEBJAxYWIClYUFRGcSFXEgtUKSJ2I4qAouG\",\n\t\t\t\"observacao\" : \"foto com extensão .jpg passada como um arquivo binário\"\n\t\t}\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_veiculo\" : 999,\n\t\"foto\" : [\n\t\t{\n\t\t\t\"nome_arquivo\" : \"imagem.png\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"link\" : \"http://hinova.com.br/wp-content/uploads/2016/08/Hinova-Logo.png\",\n\t\t\t\"observacao\" : \"foto com extensão .png passada por URL\"\n\t\t},\n\t\t{\n\t\t\t\"nome_arquivo\" : \"foto.jpg\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"binario\" : \"iVBORw0KGgoAAAANSUhEUgAAA1IAAAI2CAIAAADVVi6oAAAKQ2lDQ1BJQ0MgcHJvZmlsZQAAeNqd U3dYk/cWPt/3ZQ9WQtjwsZdsgQAiI6wIyBBZohCSAGGEEBJAxYWIClYUFRGcSFXEgtUKSJ2I4qAouG\",\n\t\t\t\"observacao\" : \"foto com extensão .jpg passada como um arquivo binário\"\n\t\t}\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_beneficiario\" : 999,\n\t\"foto\" : [\n\t\t{\n\t\t\t\"nome_arquivo\" : \"imagem.png\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"link\" : \"http://hinova.com.br/wp-content/uploads/2016/08/Hinova-Logo.png\",\n\t\t\t\"observacao\" : \"foto com extensão .png passada por URL\"\n\t\t},\n\t\t{\n\t\t\t\"nome_arquivo\" : \"foto.jpg\",\n\t\t\t\"codigo_tipo\" : 9,\n\t\t\t\"binario\" : \"iVBORw0KGgoAAAANSUhEUgAAA1IAAAI2CAIAAADVVi6oAAAKQ2lDQ1BJQ0MgcHJvZmlsZQAAeNqd U3dYk/cWPt/3ZQ9WQtjwsZdsgQAiI6wIyBBZohCSAGGEEBJAxYWIClYUFRGcSFXEgtUKSJ2I4qAouG\",\n\t\t\t\"observacao\" : \"foto com extensão .jpg passada como um arquivo binário\"\n\t\t}\n\t]\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"nome_arquivo\": \"imagem.png\",\n\t\t\"situacao\": \"Inserido\"\n\t},\n\t{\n\t\t\"nome_arquivo\": \"foto.png\",\n\t\t\"situacao\": \"Inserido\"\n\t}\n]",
          "type": "json"
        }
      ]
    },
    "filename": "class/classVeiculo.php",
    "groupTitle": "Veiculo",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
  },
  {
    "type": "post",
    "url": "/cadastrar/agregado",
    "title": "Cadastrar Agregado",
    "name": "Cadastrar_agregado",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_veiculo_vinculado",
            "description": "<p>Código do veículo ao qual o agregado será vinculado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "ano_fabricacao",
            "description": "<p>Ano fabricação do veículo. Mascara: 9999</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "ano_modelo",
            "description": "<p>Ano modelo do veículo. Mascara: 9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "chassi",
            "description": "<p>Chassi do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "numero_motor",
            "description": "<p>Número motor do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_tipo_veiculo",
            "description": "<p>Código do tipo de veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_cota",
            "description": "<p>Código da cota de participação do veículo. Deve ser selecionado baseado no valor fipe, tipo do veículo, regional e cooperativa, através do endpoint listar/cota.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_voluntario",
            "description": "<p>Código do voluntário. Será selecionado de acordo com a cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_externo",
            "description": "<p>Código externo do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_modelo",
            "description": "<p>Código do modelo do veículo. Caso esteja enviando o parâmetro <code>codigo_fipe</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_marca",
            "description": "<p>Código do marca do veículo. Caso esteja enviando o parâmetro <code>codigo_fipe</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "placa",
            "description": "<p>Placa do veículo. Caso o veículo seja ZERO KM não necessário enviar ou enviar vazio</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "renavam",
            "description": "<p>Renavam do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "kilometragem",
            "description": "<p>Kilometagem do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "cilindrada",
            "description": "<p>Cilindrada do veículo. Utilizado quando o item é motocicleta.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "allowedValues": [
              "A",
              "M",
              "0"
            ],
            "optional": true,
            "field": "cambio",
            "description": "<p>Tipo do câmbio do veículo. Ele pode ser: A(automático), M(manual) ou 0(não informado).</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_fipe",
            "description": "<p>Código fipe do veículo. caso envie o codigo_modelo. Com este código será localizado MARCA, MODELO e demais itens ligados ao item. Mascara: <code>999999-9</code> 999999-9, 999999.9, 9999999</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "dia_vencimento",
            "description": "<p>Dia de vencimento desejável pelo associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_alienacao",
            "description": "<p>Código da alienação fiduciária.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_combustivel",
            "description": "<p>Código do combustível do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cor",
            "description": "<p>Código da cor do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_categoria_veiculo",
            "description": "<p>Código da categoria veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento correspondência.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado correspondência. Informar DESCRIÇÃO ou SIGLA. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep correspondência. Mascara: 99999-999 ou 99.999-999 ou somente números. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.<br>Mascara: <code>99999999</code>, <code>99999.999</code>, <code>99999-999</code></p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero_nota",
            "description": "<p>Número da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao_nota",
            "description": "<p>Data da emissao da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato",
            "description": "<p>Data Do contrato do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "valor_adesao",
            "description": "<p>Valor da adesão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo_indicador",
            "description": "<p>Código do veículo que indicou o veículo sendo cadastrado. Caso seja enviado, o veículo indicador receberá 1 ponto</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_forma_pagamento_adesao",
            "description": "<p>Código da forma de pagamento da adesão.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_depreciacao",
            "description": "<p>Código da depreciação.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fipe_protegido",
            "description": "<p>Valor protegido do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fipe",
            "description": "<p>Valor fipe do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tabela_avaliacao",
            "description": "<p>Código da tabela de avaliação do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_classificacao",
            "description": "<p>Código da classificação.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "produtos",
            "description": "<p>Array contendo os códigos dos produtos a serem vinculados ao veículo. Obs.: Se houver algum produto compulsório que se encaixe n perfil do veículo, ele irá ser vinculado automaticamente</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "codigo_agregado",
            "description": "<p>Código do agregado inserido na base de dados</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_veiculo_vinculado\":\"999\",\n\t\"codigo_modelo\" : \"99\",\n\t\"valor_fipe\" : \"999,99\",\n\t\"ano_fabricacao\":\"yyyy\",\n\t\"placa\":\"AAA-1111\",\n\t\"chassi\":\"99999999999999999999999\",\n\t\"codigo_cota\":\"9\",\n\t\"codigo_voluntario\":\"9\",\n\t\"dia_vencimento\":\"9\",\n\t\"codigo_tipo_veiculo\":\"9\",\n\t\"codigo_categoria_veiculo\":\"9\",\n\t\"codigo_forma_pagamento_adesao\":\"9\"\n\t\"codigo_tabela_avaliacao\":\"9\",\n\t\"produtos\": [\n        {\n            \"codigo_produto\": 9\n        },\n        {\n            \"codigo_produto\": 99\n        }\n    ],\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"codigo_veiculo\": 999999,\n\t\"produtos\": [\n\t\t{\n\t\t\t\"codigo_produto\": \"9\",\n\t\t\t\"situacao\": \"Produto adicionado ao veículo\"\n\t\t},\n\t\t{\n\t\t\t\"codigo_produto\": \"99\",\n\t\t\t\"situacao\": \"Implemento adicionado ao veículo\"\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classVeiculo.php",
    "groupTitle": "Veiculo",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
          },
          {
            "group": "Header",
            "type": "Bearer",
            "optional": false,
            "field": "Authorization",
            "description": "<p>Bearer {<a href=\"#api-Autenticacao-Autenticar_Usu_rio\">token</a>}</p>"
          }
        ]
      }
    }
