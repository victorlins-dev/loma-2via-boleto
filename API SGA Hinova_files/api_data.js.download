  {
    "type": "post",
    "url": "/alterar/veiculo",
    "title": "Alterar",
    "name": "Alterar",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo que será alterado. É o único campo obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_associado",
            "description": "<p>Código do associado para vinculo ao veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa. Será selecionado de acordo com a permissão do usuário.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_voluntario",
            "description": "<p>Código do voluntário. Será selecionado de acordo com a cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "ano_fabricacao",
            "description": "<p>Ano fabricação do veículo. Mascara: 9999.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "ano_modelo",
            "description": "<p>Ano modelo do veículo. Mascara: 9999.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "placa",
            "description": "<p>Placa do veículo. Caso o veículo seja ZERO KM não necessário enviar ou enviar vazio.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "chassi",
            "description": "<p>Chassi do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "renavam",
            "description": "<p>Renavam do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero_motor",
            "description": "<p>Número motor do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "kilometragem",
            "description": "<p>Kilometagem do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "cilindrada",
            "description": "<p>Cilindrada do veículo. Utilizado quando o item é motocicleta.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_portas",
            "description": "<p>Quantidade de portas do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cambio",
            "description": "<p>Tipo do câmbio do veículo. Ele pode ser: A(automático), M(manual) ou 0(não informado).</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "codigo_fipe",
            "description": "<p>Código fipe do veículo. Com este código será localizado MARCA, MODELO e demais itens ligados ao item. Mascara: 999999-9, 999999.9, 9999999.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cota",
            "description": "<p>Código da cota de participação do veículo. Será selecionado baseado no valor fipe, tipo do veículo, regional e cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_conta",
            "description": "<p>Código da cota bancária.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "dia_vencimento",
            "description": "<p>Dia de vencimento desejável pelo associado.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_alienacao",
            "description": "<p>Código da alienação fiduciária.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_combustivel",
            "description": "<p>Código do combustível do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_cor",
            "description": "<p>Código da cor do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_veiculo",
            "description": "<p>Código do tipo de veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_categoria_veiculo",
            "description": "<p>Código da categoria veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento correspondência.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade correspondência. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado correspondência. Informar DESCRIÇÃO ou SIGLA. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_indicacao_externa",
            "description": "<p>Código da indicação externa do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep correspondência. Mascara: 99999-999 ou 99.999-999 ou somente números. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero_nota",
            "description": "<p>Número da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao_nota",
            "description": "<p>Data da emissão da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fipe_protegido",
            "description": "<p>Valor protegido do veículo escolhido pelo associado. Mascara: 999999.99</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "porcentagem_fipe_protegido",
            "description": "<p>Porcentagem protegido do veículo escolhido pelo associado</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "observacao",
            "description": "<p>Observação.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "valor_repasse",
            "description": "<p>Valor do repasse do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "forma_pagamento_repasse",
            "description": "<p>Forma de pagamento do repasse. Formato R$ ou %</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_modelo",
            "description": "<p>Código do modelo do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "gerar_cobranca_taxa_adm",
            "description": "<p>Gerar cobrança taxa administrativa. Formato &quot;Y&quot; ou &quot;N&quot;.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "gerar_cobranca_rateio",
            "description": "<p>Gerar cobrança do rateio. Formato &quot;Y&quot; ou &quot;N&quot;</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_classificacao",
            "description": "<p>Código da classificação.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fipe",
            "description": "<p>Valor fipe do veículo. Mascara: 999999.99</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_envio_boleto",
            "description": "<p>Código do tipo do envio do boleto.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato",
            "description": "<p>Data Do contrato do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_veiculo_indicador",
            "description": "<p>Código do veículo que indicou o veículo sendo cadastrado. Caso seja enviado, o veículo indicador receberá 1 ponto</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "transferir_agregados",
            "description": "<p>Array com códigos dos agregados do veículo que também deverão ser transferidos ao novo associado, caso a alteração que está sendo realizada seja uma troca de titularidade</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "valor_adesao",
            "description": "<p>Valor da adesão. Mascara: 999999.99</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_carga",
            "description": "<p>Código do tipo de carga do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_forma_pagamento_protecao",
            "description": "<p>Código da forma de pagamento da proteção.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_passageiros",
            "description": "<p>Quantidade de passageiros que o veículo suporta.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
