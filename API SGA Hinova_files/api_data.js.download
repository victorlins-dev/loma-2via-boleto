    "type": "post",
    "url": "/cooperativa/cadastrar",
    "title": "Cadastrar",
    "name": "Cadastrar",
    "version": "2.0.0",
    "group": "Cooperativa",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "nome",
            "description": "<p>Nome da cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cpf",
            "description": "<p>CPF ou CNPJ válido da cooperativa. Mascara: 999.999.999-99, 99.999.999/9999-99 ou somente números</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "email",
            "description": "<p>e-Mail da cooperativa.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "telefone",
            "description": "<p>Número de telefone da cooperativa. Mascara: 99999999999, 99 999999999, 99 99999-9999, (99) 99999-9999</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "contato",
            "description": "<p>Nome do contato responsável pela cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "logradouro",
            "description": "<p>Logradouro residêncial da  cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "numero",
            "description": "<p>Número residêncial da cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "complemento",
            "description": "<p>Complemento residêncial da cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "bairro",
            "description": "<p>Bairro residêncial da cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cidade",
            "description": "<p>Cidade residêncial da cooperativa</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "estado",
            "description": "<p>Estado residêncial da cooperativa. Informar DESCRIÇÃO ou SIGLA</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep residêncial da cooperativa. Mascara: 99999-999 ou 99.999-999 ou somente números</p>"
          }
