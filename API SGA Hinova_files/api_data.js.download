            "optional": true,
            "field": "codigo_tipo_atendimento",
            "description": "<p>Código do tipo de atendimento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_status_atendimento",
            "description": "<p>Código do status de atendimento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_departamento",
            "description": "<p>Código do departamento do atendimento.</p>"
          },
          {
            "group": "Parameter",
            "type": "string",
            "optional": true,
            "field": "data_cadastro_inicial",
            "description": "<p>Data de cadastro inicial.</p>"
          },
          {
            "group": "Parameter",
            "type": "string",
            "optional": true,
            "field": "data_cadastro_final",
            "description": "<p>Data de cadastro final.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "allowedValues": [
              "0",
              "1",
              "2",
              "3..."
            ],
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Inicia apartir de 0 e deve ser acrescentado de 1 em 1 para navegar através das proximas páginas.<br>Caso não seja enviado, a lista irá começar pelo primeiro item do retorno.</p>"
          }
        ]
      }
    },
    "success": {
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_tipo_atendimento\": 9,\n\t\"codigo_status_atendimento\": 9,\n\t\"codigo_departamento\": 9,\n\t\"data_cadastro_inicial\": \"99/99/9999\",\n\t\"data_cadastro_final\": \"99/99/9999\",\n\t\"inicio_paginacao\": 0,\n\t\"quantidade_por_pagina\": 1000\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n\t{\n\t\t\"codigo_atendimento\": \"1\",\n\t\t\"codigo_status_atendimento\": \"1\",\n\t\t\"codigo_tipo_atendimento\": \"1\",\n\t\t\"codigo_departamento\": \"1\",\n\t\t\"codigo_veiculo\": \"1\",\n\t\t\"codigo_associado\": \"1\",\n\t\t\"codigo_usuario\": \"1\",\n\t\t\"placa\": \"AAA-1234\",\n\t\t\"nome_associado\": \"nome associado\",\n\t\t\"nome_usuario\": \"nome usuario\",\n\t\t\"titulo\": \"(31)9999-9999\",\n\t\t\"descricao\": \"descricao atendimento\",\n\t\t\"data_cadastro\": \"2020-01-01T00:00:00-0300\",\n\t\t\"hora_cadastro\": \"10:10:10\",\n\t\t\"valor_atendimento\": 0\n\t}\n]",
          "type": "json"
        }
      ]
    },
    "filename": "class/classAtendimento.php",
    "groupTitle": "Atendimento",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
            "description": ""
