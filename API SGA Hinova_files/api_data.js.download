  {
    "type": "post",
    "url": "listar/evento",
    "title": "Listar",
    "name": "Listar_evento",
    "description": "<p>Retorna um array com todos os itens encontrados nos filtros desejados. O array de condutor só estará presente caso exista um condutor cadastrado no evento.</p>",
    "version": "2.0.0",
    "group": "Evento",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "data_cadastro",
            "description": "<p>Data de cadastro dos eventos. Se informada individualmente, irá retornar apenas eventos cadastrados no dia.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "protocolo",
            "description": "<p>Utilizado para buscar um evento pelo número de protocolo, anula o filtro de data_cadastro.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_cadastro_final",
            "description": "<p>Data de cadastro final dos eventos. Com ela é possível fazer um filtro de intervalo entre as datas que o evento foi cadastrado. Intervalo máximo de 30 dias.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "evento_situacao",
            "description": "<p>Filtrar por eventos que estão em situações especificadas no array.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "evento_motivo",
            "description": "<p>Filtrar por eventos que estão em motivos específicados no array.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define qual o início da paginação. Se não for enviado, o início da paginação será 0.</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Define a quantidade de registros exibidos por página. Se não for enviado, a quantidade de registros por página será de 100.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"data_cadastro\": \"dd/mm/yyyy\"\n}",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"protocolo\": \"20229999\"\n}",
        "type": "json"
      },
      {
        "title": "Exemplo Requisição:",
        "content": "{\n    \"data_cadastro\":  \"dd/mm/yyyy\",\n    \"data_cadastro_final\": \"dd/mm/yyyy\",\n    \"evento_motivo\": [1,2,3],\n    \"evento_situacao\": [1,2,3]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n[\n    {\n        \"codigo\": 99,\n        \"codigo_evento\": 99,\n        \"codigo_classificacao\": 99,\n        \"codigo_veiculo\": 99,\n        \"codigo_associado\": 99,\n        \"valor_reparo\": \"999.99\",\n        \"participacao\": 999,\n        \"passivel_ressarcimento\": \"\",\n        \"evento_tipo\": \"ASSOCIADO\",\n        \"motivo\": \"COLISÃO\",\n        \"envolvimento\": \"CAUSADOR\",\n        \"situacao_evento\": \"ABERTO\",\n        \"data_evento\": \"9999-99-99\",\n        \"hora_evento\": \"00:00:00\",\n        \"data_comunicado_evento\": \"9999-99-99\",\n        \"data_cadastro\": \"9999-99-99\",\n        \"hora_cadastro\": \"00:00:00\",\n        \"logradouro\": \"RUA MANOEL ELIAS AGUIAR\",\n        \"numero\": \"999\",\n        \"bairro\": \"OURO PRETO\",\n        \"cidade\": \"BELO HORIZONTE\",\n        \"estado\": \"MINAS GERAIS\",\n        \"cep\": \"99999-999\",\n        \"complemento\": \"COMPLEMENTO\",\n        \"numero_bo\": \"9999999\",\n        \"solicitou_carro_reserva\": \"SIM\",\n        \"descricao_evento_area\": \"DESCRIÇÃO EVENTO\",\n        \"evento_relacionado\": \"99\",\n        \"protocolo\": \"20239999\",\n        \"associado\": {\n            \"codigo\": \"99\",\n            \"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n            \"cpf\": \"99999999999\",\n            \"logradouro\": \"RUA MANOEL ELIAS AGUIAR\",\n            \"numero\": \"245\",\n            \"bairro\": \"OURO PRETO\",\n            \"cidade\": \"BELO HORIZONTE\",\n            \"estado\": \"MINAS GERAIS\",\n            \"cep\": \"99999-999\",\n            \"sexo\": \"M\",\n            \"data_nascimento\": \"9999-99-99\",\n            \"cnh\": \"99999999999999999\",\n            \"data_vencimento_habilitacao\": \"9999-99-99\",\n            \"rg\": \"MG 9999999\",\n            \"email\": \"hinova@hinova.com.br\",\n            \"email_auxiliar\": \"hinova@hinova.com.br\",\n            \"telefone\": \"(99)999999999\",\n            \"telefone_celular\": \"(99)999999999\",\n            \"telefone_comercial\": \"(99)999999999\"\n        },\n        \"veiculo\": {\n            \"codigo\": \"99\",\n            \"placa\": \"AAA0000\",\n            \"data_contrato\": \"9999-99-99\",\n            \"chassi\": \"999999999999999\",\n            \"ano_fabricacao\": \"9999\",\n            \"ano_modelo\": \"9999\",\n            \"valor_fipe\": \"9999.99\",\n            \"renavam\": \"999999999\",\n            \"quantidade_portas\": \"9\",\n            \"numero_motor\": \"9\",\n            \"tipo\": \"TIPO\",\n            \"modelo\": \"VEICULO\",\n            \"cor\": \"COR\",\n            \"situacao\": \"SITUAÇÃO\",\n            \"marca\": \"MARCA\",\n            \"categoria\": \"CATEGORIA\",\n            \"classificacao\": \"NÃO INFORMADO\",\n            \"combustivel\": \"COMBUSTIVEL\"\n        },\n        \"regional\": {\n            \"codigo\": \"99\",\n            \"descricao\": \"HINOVA SOLUÇÕES DIGITAIS\"\n        },\n        \"cooperativa\": {\n            \"codigo\": \"99\",\n            \"descricao\": \"HINOVA SOLUÇÕES DIGITAIS\"\n        },\n        \"voluntario\": {\n            \"codigo\": \"99\",\n            \"descricao\": \"HINOVA SOLUÇÕES DIGITAIS\"\n        },\n        \"condutor\": {\n            \"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n            \"cpf\": \"99999999999\",\n            \"logradouro\": \"RUA MANOEL ELIAS AGUIAR\",\n            \"numero\": \"245\",\n            \"bairro\": \"OURO PRETO\",\n            \"cidade\": \"BELO HORIZONTE\",\n            \"estado\": \"MINAS GERAIS\",\n            \"cep\": \"99999-999\",\n            \"telefone\": \"(99) 99999-9999\"\n        }\n    }\n]",
          "type": "json"
        },
