          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "formato_cobranca",
            "description": "<p>Formato de cobrança do veículo. Mascara: B ou C.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "qtde_parcela",
            "description": "<p>Quantidade de parcelas.</p>"
          },
