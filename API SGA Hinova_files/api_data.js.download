  {
    "type": "post",
    "url": "/vincular/implemento",
    "title": "Vincular implemento",
    "description": "<p>Vincula um implemento a um certo veículo</p>",
    "name": "Vincular_Implemento",
    "version": "2.0.0",
    "group": "Veiculo",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_implemento",
            "description": "<p>Código do implemento a ser vinculado</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "valor_fipe",
            "description": "<p>Valor FIPE do implemento.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "porcentagem",
            "description": "<p>Porcentagem cobrada do implemento.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "somar_fipe",
            "description": "<p>Define se deseja ou não somar ao valor FIPE do veículo. Deve ser no formato &quot;Y&quot;(sim) ou &quot;N&quot;(não)</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
            "field": "mensagem",
            "description": "<p>Mensagem de retorno</p>"
          },
          {
            "group": "Success 200",
            "type": "Number",
            "optional": false,
            "field": "codigo_veiculo",
            "description": "<p>Código do veículo que recebeu o vinculo do implemento</p>"
          }
        ]
      },
      "examples": [
        {
          "title": "Exemplo Requisição:",
          "content": "{\n\t\"codigo_veiculo\" : \"999\",\n\t\"codigo_implemento\" : \"9\",\n\t\"valor_fipe\" : \"99,99\",\n\t\"somar_fipe\" : \"N\",\n\t\"porcentagem\" : \"9,99\"\n}",
          "type": "json"
        },
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"codigo_veiculo\": 999,\n\t\"codigo_implemento\": 9\n}",
          "type": "json"
        }
      ]
    },
