          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "cep",
            "description": "<p>Cep correspondência. Mascara: 99999-999 ou 99.999-999 ou somente números. Caso um dos campos que compõe o endereço seja enviando os demais se tornam obrigatórios</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "numero_nota",
            "description": "<p>Número da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_emissao_nota",
            "description": "<p>Data da emissão da nota fiscal do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato",
            "description": "<p>Data Do contrato do veículo.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "valor_adesao",
            "description": "<p>Valor da adesão.</p>"
          },
