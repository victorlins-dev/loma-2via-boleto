            "description": "<p>Sexo do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "categoria_cnh",
            "description": "<p>Categoria da CNH do beneficiário.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "codigo_tipo_cobranca_recorrente",
            "description": "<p>Código do tipo de cobrança recorrente. <br>Lista de tipo cobranca recorrente {<a href=\"#api-Boleto-Listar_tipo_cobran_a_recorrente\">aqui</a>}.</p>"
          }
        ]
      }
    },
    "success": {
      "fields": {
        "Success 200": [
          {
            "group": "Success 200",
            "type": "Number",
            "optional": false,
            "field": "codigo",
            "description": "<p>Código de retorno. Ex: 200, 203, 401 etc</p>"
          },
          {
            "group": "Success 200",
            "type": "String",
            "optional": false,
