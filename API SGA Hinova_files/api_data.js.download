  {
    "type": "get",
    "url": "listar/cota/:codigo_regional/:codigo_cooperativa/:codigo_tipo_veiculo/:valor_fipe/:cilindrada",
    "title": "Listar",
    "description": "<p>Lista cotas de acordo com regional, cooperativa, tipo veículo, valor Fipe ou cilindrada</p>",
    "name": "Listar_Cota",
    "version": "2.0.0",
    "group": "Cota",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_regional",
            "description": "<p>Código da regional na qual as cotas estão vinculadas</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_cooperativa",
            "description": "<p>Código da cooperativa na qual as cotas estão vinculadas</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_tipo_veiculo",
            "description": "<p>Código do tipo veículo</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "valor_fipe",
            "description": "<p>Valor protegido do veículo. Deve ser enviado com valor decimal Ex.: 100,00. Pode ser enviado 0 caso o veículo seja baseado em cilindrada.</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": false,
            "field": "cilindrada",
            "description": "<p>Cilindrada do veículo. Pode ser enviado 0 quando o veículo é baseado em valor fipe</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "/listar/cota/9/9/9/99,99/0",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"cota\": [\n\t\t{\n\t\t\t\"codigo_cota\": \"99\",\n\t\t\t\"cota\": 9.99,\n\t\t\t\"descricao_cota\": \"COTA 9,99\",\n\t\t\t\"valor_cota\": \"99.9999\",\n\t\t\t\"valor_fipe_inicial\": 999999,\n\t\t\t\"valor_fipe_final\": 99999,\n\t\t\t\"valor_adesao\": 9,\n\t\t\t\"participacao_minima\": 99,\n\t\t\t\"porcentagem_fipe\": 9,\n\t\t\t\"formato_cobranca\": \"R$\",\n\t\t\t\"descricao_tipo_veiculo\": \"AUTOMÓVEL\",\n\t\t\t\"regionais\": [\n\t\t\t\t{\n\t\t\t\t\t\"codigo_regional\": \"9\",\n\t\t\t\t\t\"nome_regional\": \"HINOVA SOLUÇÕES DIGITAIS\"\n\t\t\t\t}\n\t\t\t]\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
