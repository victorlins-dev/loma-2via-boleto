  {
    "type": "post",
    "url": "listar/associado",
    "title": "Listar",
    "name": "Listar_Associado",
    "description": "<p>Lista os associados de acordo com a situação especificada</p>",
    "version": "2.0.0",
    "group": "Associado",
    "parameter": {
      "fields": {
        "Parameter": [
          {
            "group": "Parameter",
            "type": "Number",
            "optional": false,
            "field": "codigo_situacao",
            "description": "<p>Define qual a situação dos associados a serem listados. O codigo_situacao é obrigatório</p>"
          },
          {
            "group": "Parameter",
            "type": "Array",
            "optional": true,
            "field": "codigo_regional",
            "description": "<p>Array de códigos de regionais para listar os associados</p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_cadastro",
            "description": "<p>Data de cadastro inicial do associado Mascara: <code>d/m/a</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_cadastro_final",
            "description": "<p>Data de cadastro final do associado Mascara: <code>d/m/a</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato",
            "description": "<p>Data de contrato inicial do associado Mascara: <code>d/m/a</code></p>"
          },
          {
            "group": "Parameter",
            "type": "String",
            "optional": true,
            "field": "data_contrato_final",
            "description": "<p>Data de contrato final do associado Mascara: <code>d/m/a</code></p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "quantidade_por_pagina",
            "description": "<p>Quantidade de registros a serem exibidos por página. Caso não seja enviado, vai respeitar a quantidade limite do endpoint.</p>"
          },
          {
            "group": "Parameter",
            "type": "Number",
            "optional": true,
            "field": "inicio_paginacao",
            "description": "<p>Define que qual item a lista deve começar. Caso não seja enviado, a lista irá começar pelo primeiro item do retorno. <br> A paginação funciona como um OFFSET.<br>Se o parametro <code>quantidade_por_pagina</code> = 1000;<br>A página 1 se inicia em 0;<br>página 2 em 1000;<br>página 3 em 2000 e assim por diante.</p>"
          }
        ]
      }
    },
    "examples": [
      {
        "title": "Exemplo Requisição:",
        "content": "{\n\t\"codigo_situacao\" : 9,\n\t\"inicio_paginacao\" : 0,\n\t\"quantidade_por_pagina\" : 999,\n\t\"data_cadastro\": \"99/99/9999\",\n\t\"data_cadastro_final\":\"99/99/9999\"\n\t\"codigo_regional\": [\n\t\t\"9\"\n\t]\n}",
        "type": "json"
      }
    ],
    "success": {
      "examples": [
        {
          "title": "Exemplo Retorno:",
          "content": "HTTP/1.1 200 OK\n{\n\t\"mensagem\": \"OK\",\n\t\"total_associados\": \"999999\",\n\t\"mostrando \": \"9\",\n\t\"numero_paginas\": 99,\n\t\"pagina_corrente\": 9,\n\t\"mostrando\": 999,\n\t\"associados\": [\n\t\t{\n\t\t\t\"codigo_associado\": \"999\",\n\t\t\t\"codigo_situacao\": \"9\",\n\t\t\t\"nome\": \"HINOVA SOLUÇÕES DIGITAIS\",\n\t\t\t\"sexo\": \"M\",\n\t\t\t\"tipo_pessoa\": \"FÍSICA\",\n\t\t\t\"data_nascimento\": \"1990-01-01\",\n\t\t\t\"rg_associado\": \"9999999999\",\n\t\t\t\"orgao_expedidor_rg\": \"MG\",\n\t\t\t\"data_expedicao_rg\": \"2000-01-01\",\n\t\t\t\"cnh\": \"9999999999999\",\n\t\t\t\"categoria_cnh\": \"B\",\n\t\t\t\"data_vencimento_habilitacao\": \"2036-01-01\",\n\t\t\t\"cpf\": \"999999999999999\",\n\t\t\t\"codigo_classificacao\": \"99\",\n\t\t\t\"ddd\": \"99\",\n\t\t\t\"telefone\": \"9999-9999\",\n\t\t\t\"ddd_celular\": \"99\",\n\t\t\t\"telefone_celular\": \"99999-9999\",\n\t\t\t\"ddd_celular_aux\": \"99\",\n\t\t\t\"telefone_celular_aux\": \"9999-9999\",\n\t\t\t\"ddd_comercial\": \"99\",\n\t\t\t\"telefone_comercial\": \"9999-9999\",\n\t\t\t\"email\": \"hinova@hotmail.com\",\n\t\t\t\"email_auxiliar\": \"hinova@hotmail.com\",\n\t\t\t\"cep\": \"99999-999\",\n\t\t\t\"logradouro\": \"LOGRADOURO\",\n\t\t\t\"numero\": \"887\",\n\t\t\t\"complemento\": \"COMPLEMENTO\",\n\t\t\t\"bairro\": \"BAIRRO\",\n\t\t\t\"cidade\": \"CIDADE\",\n\t\t\t\"estado\": \"MG\",\n\t\t\t\"data_cadastro_associado\": \"2019-01-01\",\n\t\t\t\"data_contrato_associado\": \"2019-01-01\",\n\t\t\t\"hora_contrato_associado\": \"00:00:00\",\n\t\t\t\"radio\": \"999\",\n\t\t\t\"radio2\": \"999\",\n\t\t\t\"dia_vencimento\": \"99\",\n\t\t\t\"filhos\": 9,\n\t\t\t\"codigo_profissao\": \"9\",\n\t\t\t\"codigo_regional\": \"9\",\n\t\t\t\"codigo_cooperativa\": \"9\",\n\t\t\t\"pontos\": \"9.99\",\n\t\t\t\"codigo_voluntario\": 9\n\t\t}\n\t]\n}",
          "type": "json"
        }
      ]
    },
    "filename": "class/classAssociado.php",
    "groupTitle": "Associado",
    "header": {
      "fields": {
        "Header": [
          {
            "group": "Header",
            "type": "String",
            "optional": false,
            "field": "Content-Type",
            "defaultValue": "application/json",
